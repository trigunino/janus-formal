import JanusFormal.Foundations.ProgramMPrimitiveDescent

/-!
# MF-DESC-002: global reachability is generated by local primitive witnesses

Under primitive descent, global reachability is exactly the reflexive-transitive
closure of locally witnessed primitive steps.
-/

namespace JanusFormal.ProgramM

universe u v w

/-- General local-to-global reachability theorem. -/
theorem reachability_iff_local_witness_chain
    {ι : Type w} {Obj : Type u} {Rel : Type v}
    {global : RelationalSystem Obj Rel} (atlas : RelationalAtlas ι global)
    (hDescent : PrimitiveDescent atlas) (q : Rel) (x y : Obj) :
    reachability global q x y ↔
      Relation.ReflTransGen (HasLocalWitness atlas q) x y := by
  constructor
  · intro h
    exact Relation.ReflTransGen.lift id
      (fun a b hab ↦ (hDescent q a b).1 hab) h
  · intro h
    exact Relation.ReflTransGen.lift id
      (fun a b hab ↦ (hDescent q a b).2 hab) h

/-- Every single locally witnessed step contributes to global reachability. -/
theorem local_witness_reaches
    {ι : Type w} {Obj : Type u} {Rel : Type v}
    {global : RelationalSystem Obj Rel} (atlas : RelationalAtlas ι global)
    (hDescent : PrimitiveDescent atlas) {q : Rel} {x y : Obj}
    (hLocal : HasLocalWitness atlas q x y) :
    reachability global q x y := by
  exact (reachability_iff_local_witness_chain atlas hDescent q x y).2
    (Relation.ReflTransGen.single hLocal)

/-- Concatenation of chains generated in different patches is a global
operation; it is not necessary for one patch to witness the entire chain. -/
theorem local_witness_chains_compose
    {ι : Type w} {Obj : Type u} {Rel : Type v}
    {global : RelationalSystem Obj Rel} (atlas : RelationalAtlas ι global)
    (hDescent : PrimitiveDescent atlas) {q : Rel} {x y z : Obj}
    (hxy : Relation.ReflTransGen (HasLocalWitness atlas q) x y)
    (hyz : Relation.ReflTransGen (HasLocalWitness atlas q) y z) :
    reachability global q x z := by
  apply (reachability_iff_local_witness_chain atlas hDescent q x z).2
  exact hxy.trans hyz

end JanusFormal.ProgramM
