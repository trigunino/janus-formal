universe u v w x

/--
Corrected constructive form of Lemma 2: a finite-jet evaluator yields a natural
operator exactly when it is equivariant, provided every abstract jet is
realized by a section.
-/
theorem lemma_two_constructive_equivalence
    {Symmetry : Type u}
    {SectionSpace : Type v}
    {Jet : Type w}
    {Target : Type x}
    (data : FiniteJetConstruction Symmetry SectionSpace Jet Target) :
    IsNaturalOperator data.sectionAction data.targetAction
        (inducedOperator data) ↔
      IsEquivariant data.jetAction data.targetAction data.evaluator :=
  induced_operator_natural_iff_evaluator_equivariant data

/--
Lemma 3 cannot assert polynomiality for all smooth local natural operators.
The pointwise exponential is already an order-zero counterexample.
-/
theorem strong_polynomial_lemma_three_is_false :
    Not (HasFiniteDifferencePolynomialCertificate Real.exp) :=
  exp_has_no_finite_difference_polynomial_certificate

/--
A rigorous finite fragment of Lemma 3: degree-at-most-two scalar invariants on
the displayed local vector representation are generated by `1` and `|v|^2`.
-/
theorem lemma_three_quadratic_vector_fragment
    (polynomial : QuadraticPolynomial3)
    (hInvariant : SignedPermutationInvariant polynomial)
    (vector : P0EFTJanusVectorInvariantPairing.Vector3) :
    evaluate polynomial vector =
      polynomial.constant + polynomial.xx * normSquared vector :=
  invariant_quadratic_evaluation polynomial hInvariant vector

/--
The exact finite local core of Lemma 4: vector and spin-two pairings are
one-dimensional up to scale, discrete grades remove selected mixed blocks, and
repeated irreducibles retain multiplicity-matrix freedom.
-/
theorem lemma_four_core_pairing_matrix :=
  core_pairing_classification_matrix

/--
Corrected Lemma 5.  The analytic Peetre--Slovak step supplies a finite-jet
presentation.  Naturality and jet realizability then produce the unique smooth
equivariant evaluator.
-/
theorem lemma_five_corrected_local_universality
    {Symmetry : Type u}
    {Section : Type v}
    {Jet : Type w}
    {Target : Type x}
    (data : CorrectedLocalJetData Symmetry Section Jet Target)
    (hNatural :
      IsNaturalOperator data.presentation.sectionAction
        data.presentation.targetAction
        data.presentation.operator) :
    ∃! evaluator : Jet → Target,
      (∀ sectionValue,
        data.presentation.operator sectionValue =
          evaluator (data.presentation.jet sectionValue)) /\
      IsEquivariant data.presentation.jetAction
        data.presentation.targetAction evaluator :=
  corrected_local_jet_universality data hNatural

/-- Identical natural principal symbols do not determine the full operator. -/
theorem principal_symbol_does_not_close_lemma_five :
    ∃ first second : ScalarLaplaceTypeModel,
      (∀ normSquared field,
        principalSymbol first normSquared field =
          principalSymbol second normSquared field) /\
      fullOperator first 0 1 ≠ fullOperator second 0 1 :=
  principal_symbol_does_not_determine_full_operator

/-- Machine-checked core status of the five-lemma program. -/
structure FiveLemmaAuditStatus where
  lemmaOneWrittenAnalyticProofPresent : Prop
  lemmaOneWhitneyAndPeetreSlovakFormalizedInLean : Prop
  lemmaTwoAbstractEquivarianceProvedInLean : Prop
  lemmaTwoJanusAdaptedJetGroupConstructed : Prop
  lemmaThreeStrongPolynomialClaimRejected : Prop
  lemmaThreeQuadraticVectorFragmentProved : Prop
  lemmaThreeFullSmoothInvariantClassificationProved : Prop
  lemmaFourCorePairingsProved : Prop
  lemmaFourGlobalBundlePairingsProved : Prop
  lemmaFiveCorrectedConditionalUniversalityProved : Prop
  lemmaFiveActualJanusSpecializationProved : Prop
  lowerOrderFreedomSeparated : Prop

/-- What is presently proved independently of the missing global Janus geometry. -/
def verifiedAbstractCoreClosed
    (s : FiveLemmaAuditStatus) : Prop :=
  s.lemmaOneWrittenAnalyticProofPresent /\
  s.lemmaTwoAbstractEquivarianceProvedInLean /\
  s.lemmaThreeStrongPolynomialClaimRejected /\
  s.lemmaThreeQuadraticVectorFragmentProved /\
  s.lemmaFourCorePairingsProved /\
  s.lemmaFiveCorrectedConditionalUniversalityProved /\
  s.lowerOrderFreedomSeparated

/-- Complete specialization to the actual decorated Janus category. -/
def fullJanusFiveLemmaClosure
    (s : FiveLemmaAuditStatus) : Prop :=
  verifiedAbstractCoreClosed s /\
  s.lemmaOneWhitneyAndPeetreSlovakFormalizedInLean /\
  s.lemmaTwoJanusAdaptedJetGroupConstructed /\
  s.lemmaThreeFullSmoothInvariantClassificationProved /\
  s.lemmaFourGlobalBundlePairingsProved /\
  s.lemmaFiveActualJanusSpecializationProved

/-- Missing the actual adapted SpinC/PT/Z4/BRST jet group blocks the Janus theorem. -/
theorem missing_adapted_jet_group_blocks_full_closure
    (s : FiveLemmaAuditStatus)
    (hMissing : Not s.lemmaTwoJanusAdaptedJetGroupConstructed) :
    Not (fullJanusFiveLemmaClosure s) := by
  intro hClosed
  exact hMissing hClosed.2.2.1

/-- Missing globalization of pointwise pairings blocks the full theorem. -/
theorem missing_pairing_globalization_blocks_full_closure
    (s : FiveLemmaAuditStatus)
    (hMissing : Not s.lemmaFourGlobalBundlePairingsProved) :
    Not (fullJanusFiveLemmaClosure s) := by
  intro hClosed
  exact hMissing hClosed.2.2.2.2.1

/--
Sharp verdict:

* Lemma 1 is a checked written analytic proof but not a Lean formalization of
  Whitney extension or Peetre--Slovak;
* Lemma 2 and the corrected conditional Lemma 5 are formalized abstractly;
* Lemmas 3 and 4 have rigorous finite representation fragments, while the full
  smooth-invariant/global-bundle classification remains open;
* no lemma makes ellipticity, lower-order dynamics or normalization automatic.
-/
structure FiveLemmaVerdict where
  finiteJetReductionLocalNotGlobal : Prop
  naturalityEquivarianceConditionalOnRealization : Prop
  smoothNotAutomaticallyPolynomial : Prop
  finiteInvariantFragmentsAvailable : Prop
  multiplicityFreedomExplicit : Prop
  correctedUniversalityConditional : Prop
  actualJanusSpecializationOpen : Prop
  lowerOrderDynamicsIndependent : Prop


def fiveLemmaVerdictClosed
    (s : FiveLemmaVerdict) : Prop :=
  s.finiteJetReductionLocalNotGlobal /\
  s.naturalityEquivarianceConditionalOnRealization /\
  s.smoothNotAutomaticallyPolynomial /\
  s.finiteInvariantFragmentsAvailable /\
  s.multiplicityFreedomExplicit /\
  s.correctedUniversalityConditional /\
  s.actualJanusSpecializationOpen /\
  s.lowerOrderDynamicsIndependent

end P0EFTJanusCorrectedFiveLemmaChain
end JanusFormal
