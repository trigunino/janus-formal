import Mathlib

namespace JanusFormal
namespace P0EFTJanusTwistedMappingGenerator

set_option autoImplicit false

variable {X : Type*}

/-- Mapping-torus generator `(x,u) ↦ (rho x,u+T)`. -/
def mappingGenerator (rho : X ≃ X) (period : ℝ) :
    (X × ℝ) ≃ (X × ℝ) where
  toFun p := (rho p.1, p.2 + period)
  invFun p := (rho.symm p.1, p.2 - period)
  left_inv p := by
    rcases p with ⟨x, u⟩
    simp
  right_inv p := by
    rcases p with ⟨x, u⟩
    simp

@[simp] theorem mapping_generator_apply
    (rho : X ≃ X) (period : ℝ) (p : X × ℝ) :
    mappingGenerator rho period p =
      (rho p.1, p.2 + period) :=
  rfl

/-- Pure translation by the doubled period. -/
def doubleTranslation (period : ℝ) :
    (X × ℝ) ≃ (X × ℝ) where
  toFun p := (p.1, p.2 + 2 * period)
  invFun p := (p.1, p.2 - 2 * period)
  left_inv p := by
    rcases p with ⟨x, u⟩
    simp
    ring
  right_inv p := by
    rcases p with ⟨x, u⟩
    simp
    ring

/-- If `rho` is involutive, the square generator is pure translation by `2T`. -/
theorem mapping_generator_square_apply
    (rho : X ≃ X)
    (period : ℝ)
    (hInvolutive : ∀ x, rho (rho x) = x)
    (p : X × ℝ) :
    mappingGenerator rho period
        (mappingGenerator rho period p) =
      doubleTranslation period p := by
  rcases p with ⟨x, u⟩
  simp [mappingGenerator, doubleTranslation, hInvolutive]
  ring

/-- Equality of the two equivalences, not just pointwise application. -/
theorem mapping_generator_square_eq_double_translation
    (rho : X ≃ X)
    (period : ℝ)
    (hInvolutive : ∀ x, rho (rho x) = x) :
    (mappingGenerator rho period).trans
        (mappingGenerator rho period) =
      doubleTranslation period := by
  ext p
  exact mapping_generator_square_apply rho period hInvolutive p

/--
The index-two subgroup generated by the square has no reflection on `X`; its
quotient is the orientation-cover candidate with period `2T`.
-/
structure OrientationCoverConstructionStatus where
  generatorActsProperlyDiscontinuously : Prop
  quotientByGeneratorConstructed : Prop
  squareSubgroupIndexTwoProved : Prop
  squareQuotientConstructed : Prop
  squareQuotientIdentifiedWithProductCircle : Prop
  deckInvolutionDerived : Prop


def orientationCoverConstructionClosed
    (s : OrientationCoverConstructionStatus) : Prop :=
  s.generatorActsProperlyDiscontinuously /\
  s.quotientByGeneratorConstructed /\
  s.squareSubgroupIndexTwoProved /\
  s.squareQuotientConstructed /\
  s.squareQuotientIdentifiedWithProductCircle /\
  s.deckInvolutionDerived

end P0EFTJanusTwistedMappingGenerator
end JanusFormal
