open P0EFTJanusRieszShapeOperatorProjectedSeedAdaptedFramePair
open P0EFTJanusRieszShapeOperatorProjectedSeedOpenInstantiation

universe u v w x y

variable {Base : Type w} {Tangent : Type u}
variable {Normal : Type v} {Ambient : Type x}
variable [NormedAddCommGroup Base] [NormedSpace ℝ Base]
variable [NormedAddCommGroup Tangent] [InnerProductSpace ℝ Tangent]
variable [NormedAddCommGroup Normal] [InnerProductSpace ℝ Normal]
variable [NormedAddCommGroup Ambient] [InnerProductSpace ℝ Ambient]
variable [FiniteDimensional ℝ Tangent]
variable [FiniteDimensional ℝ Normal]
variable [FiniteDimensional ℝ Ambient]

variable {ι κ : Type y}
variable [Fintype ι] [Fintype κ]
variable [LinearOrder κ] [LocallyFiniteOrderBot κ] [WellFoundedLT κ]

/-- Constant identity orthogonal frame on an arbitrary chart domain. -/
def identitySmoothOrthogonalFrameFamilyOn
    {Fiber : Type*}
    [NormedAddCommGroup Fiber] [InnerProductSpace ℝ Fiber]
    (domain : Set Base) :
    SmoothOrthogonalFrameFamilyOn Base Fiber domain where
  frame := fun _ => LinearIsometryEquiv.refl ℝ Fiber
  forward_contDiffOn := contDiffOn_const
  inverse_contDiffOn := contDiffOn_const

/-- Remaining coefficient-level input after the projected-seed tangent and
normal geometry has been constructed canonically.

All frame, range, overlap and descent data are generated from these fields. -/
structure CanonicalProjectedSeedRieszData where
  basisData : PointwiseNormalBasisData Base Ambient ι κ
  ambientDimension :
    Fintype.card ι + Fintype.card κ = finrank ℝ Ambient
  tangentBasis : Basis ι ℝ Tangent
  tangentBasis_orthonormal : Orthonormal ℝ tangentBasis
  normalBasis : Basis κ ℝ Normal
  normalBasis_orthonormal : Orthonormal ℝ normalBasis
  physicalOperator : Base → Tangent →L[ℝ] Tangent
  referenceForm : Base → Base → ContinuousSecondFundamentalForm
    (Tangent := Tangent) (Normal := Normal)
  physicalNormal : Base → Normal
  referenceForm_contDiffOn :
    ∀ center,
      ContDiffOn ℝ ∞ (referenceForm center)
        (pointwiseBasisChartDomain basisData center)
  physicalNormal_contDiffOn :
    ∀ center,
      ContDiffOn ℝ ∞ physicalNormal
        (pointwiseBasisChartDomain basisData center)
  reference_realizes_physical :
    ∀ center base,
      base ∈ pointwiseBasisChartDomain basisData center →
      geometricRieszShapeFamilyOn
          (identitySmoothOrthogonalFrameFamilyOn
            (Fiber := Tangent) (pointwiseBasisChartDomain basisData center))
          (identitySmoothOrthogonalFrameFamilyOn
            (Fiber := Normal) (pointwiseBasisChartDomain basisData center))
          (referenceForm center) physicalNormal base =
        physicalOperator base

/-- Canonical tangent physical frame generated by the supplied tangent frame. -/
def CanonicalProjectedSeedRieszData.physicalTangentFrame
    (data : CanonicalProjectedSeedRieszData
      (Base := Base) (Tangent := Tangent) (Normal := Normal)
      (Ambient := Ambient) (ι := ι) (κ := κ))
    (center : Base) :
    PhysicalTangentFrameOn (TangentModel := Tangent)
      data.basisData center :=
  canonicalPhysicalTangentFrameOn data.tangentBasis
    data.tangentBasis_orthonormal data.basisData center

/-- Canonical normal physical frame whose range is the tangent orthogonal
complement. -/
def CanonicalProjectedSeedRieszData.physicalNormalFrame
    (data : CanonicalProjectedSeedRieszData
      (Base := Base) (Tangent := Tangent) (Normal := Normal)
      (Ambient := Ambient) (ι := ι) (κ := κ))
    (center : Base) :
    PhysicalNormalFrameOn (Model := Normal) data.basisData center :=
  projectedSeedOrthogonalPhysicalNormalFrameOn data.normalBasis
    data.normalBasis_orthonormal data.basisData data.ambientDimension center

/-- Canonical simultaneous tangent/normal transition on a projected-seed chart. -/
def CanonicalProjectedSeedRieszData.transition
    (data : CanonicalProjectedSeedRieszData
      (Base := Base) (Tangent := Tangent) (Normal := Normal)
      (Ambient := Ambient) (ι := ι) (κ := κ))
    (center : Base) :
    SmoothResidualOrthogonalFrameFamilyOn Base Tangent Normal
      (pointwiseBasisChartDomain data.basisData center) :=
  projectedSeedResidualTransition data.tangentBasis
    data.tangentBasis_orthonormal data.normalBasis
    data.normalBasis_orthonormal data.basisData center
    (data.physicalTangentFrame center)
    (by
      intro base hValid
      rfl)
    (data.physicalNormalFrame center)
    (projectedSeedOrthogonalRangeIdentification data.normalBasis
      data.normalBasis_orthonormal data.basisData data.ambientDimension center)

/-- Canonical projected-seed data instantiates the complete open-chart Riesz
descent interface. -/
def CanonicalProjectedSeedRieszData.toOpenRieszInstantiationData
    (data : CanonicalProjectedSeedRieszData
      (Base := Base) (Tangent := Tangent) (Normal := Normal)
      (Ambient := Ambient) (ι := ι) (κ := κ)) :
    ProjectedSeedOpenRieszInstantiationData
      (Base := Base) (Ambient := Ambient)
      (Tangent := Tangent) (Normal := Normal) (ι := ι) (κ := κ) where
  basisData := data.basisData
  physicalOperator := data.physicalOperator
  referenceTangentFrame := fun center =>
    identitySmoothOrthogonalFrameFamilyOn
      (Fiber := Tangent) (pointwiseBasisChartDomain data.basisData center)
  referenceNormalFrame := fun center =>
    identitySmoothOrthogonalFrameFamilyOn
      (Fiber := Normal) (pointwiseBasisChartDomain data.basisData center)
  transition := data.transition
  referenceForm := data.referenceForm
  physicalNormal := data.physicalNormal
  referenceForm_contDiffOn := data.referenceForm_contDiffOn
  physicalNormal_contDiffOn := data.physicalNormal_contDiffOn
  reference_realizes_physical := data.reference_realizes_physical

/-- The physical Riesz family is globally smooth from coefficient smoothness and
the reference realization identity; all frame and overlap obligations have been
discharged by the projected-seed construction. -/
theorem CanonicalProjectedSeedRieszData.physicalOperator_contDiff
    {AtlasTangent AtlasNormal : Type*}
    (data : CanonicalProjectedSeedRieszData
      (Base := Base) (Tangent := Tangent) (Normal := Normal)
      (Ambient := Ambient) (ι := ι) (κ := κ)) :
    ContDiff ℝ ∞ data.physicalOperator := by
  exact ProjectedSeedOpenRieszInstantiationData.physicalOperator_contDiff
    (TangentModel := AtlasTangent) (NormalModel := AtlasNormal)
    data.toOpenRieszInstantiationData

/-- Audit boundary after canonical projected-seed assembly. -/
structure CanonicalProjectedSeedAssemblyStatus where
  orthogonalNormalRangeProved : Prop
  tangentFramePackaged : Prop
  residualTransitionConstructed : Prop
  referenceSecondFundamentalFormSmooth : Prop
  physicalNormalFieldSmooth : Prop
  referenceRealizationProved : Prop
  openRieszDataInstantiated : Prop
  globalPhysicalRieszSmooth : Prop
  instantiatedOnActualJanusJets : Prop

/-- Closure of canonical projected-seed Riesz assembly. -/
def canonicalProjectedSeedAssemblyClosed
    (s : CanonicalProjectedSeedAssemblyStatus) : Prop :=
  s.orthogonalNormalRangeProved ∧
  s.tangentFramePackaged ∧
  s.residualTransitionConstructed ∧
  s.referenceSecondFundamentalFormSmooth ∧
  s.physicalNormalFieldSmooth ∧
  s.referenceRealizationProved ∧
  s.openRieszDataInstantiated ∧
  s.globalPhysicalRieszSmooth ∧
  s.instantiatedOnActualJanusJets

/-- After canonical assembly, the final substantive boundary is instantiation of
`referenceForm`, `physicalNormal` and the realization law on the true Janus jet
base. -/
theorem missing_actual_janus_coefficients_blocks_final_closure
    (s : CanonicalProjectedSeedAssemblyStatus)
    (hMissing : Not s.instantiatedOnActualJanusJets) :
    Not (canonicalProjectedSeedAssemblyClosed s) := by
  intro hClosed
  exact hMissing hClosed.2.2.2.2.2.2.2.2

end

end P0EFTJanusRieszShapeOperatorCanonicalProjectedSeedAssembly
end JanusFormal
