import Mathlib.GroupTheory.QuotientGroup.Basic
import JanusFormal.Branches.FundamentalGeometryPEJetUniversality.Gates.P0EFTJanusCliffordSpin2Bridge

namespace JanusFormal
namespace P0EFTJanusCliffordSpin2DoubleCover

set_option autoImplicit false

noncomputable section

open P0EFTJanusCentralLiftCocycleObstruction
open P0EFTJanusSpinCDiagonalDefectCancellation
open P0EFTJanusDeterminantSquareRootDefect
open P0EFTJanusCirclePhaseTwoTorsion
open P0EFTJanusSpin2CircleModel
open P0EFTJanusCircleSO2Equivalence
open P0EFTJanusCliffordSpin2Bridge

universe u

/-- Mathlib's Clifford model of `Spin(2)` is commutative because it is group
isomorphic to the unit circle. -/
theorem cliffordSpin2_mul_comm
    (first second : CliffordSpin2) :
    first * second = second * first := by
  apply circleEquivCliffordSpin2.symm.injective
  rw [map_mul, map_mul]
  exact mul_comm _ _

/-- The transported group structure is commutative. This local instance is used
to construct the diagonal SpinC quotient. -/
local instance cliffordSpin2CommGroup : CommGroup CliffordSpin2 :=
  { (inferInstance : Group CliffordSpin2) with
    mul_comm := cliffordSpin2_mul_comm }

/-- Distinguished central kernel element in the Clifford model. -/
def cliffordSpin2MinusOne : CliffordSpin2 :=
  circleEquivCliffordSpin2 (-1)

@[simp]
theorem cliffordSpin2MinusOne_projection :
    cliffordSpin2ToMatrixSO2Projection cliffordSpin2MinusOne = 1 := by
  rw [cliffordSpin2MinusOne,
    cliffordSpin2ToMatrixSO2Projection_circle]
  exact spin2MatrixSO2DoubleCover.minusOne_mem_kernel

/-- The distinguished Clifford kernel element is nontrivial. -/
theorem cliffordSpin2MinusOne_ne_one :
    cliffordSpin2MinusOne ≠ 1 := by
  intro hEqual
  apply Circle.neg_ne_self 1
  have hTransported :=
    congrArg (fun rotor => circleEquivCliffordSpin2.symm rotor) hEqual
  simpa [cliffordSpin2MinusOne] using hTransported

@[simp]
theorem cliffordSpin2MinusOne_sq :
    cliffordSpin2MinusOne * cliffordSpin2MinusOne = 1 := by
  apply circleEquivCliffordSpin2.symm.injective
  simp [cliffordSpin2MinusOne]

/-- Exact kernel theorem for the Clifford-valued Spin projection. -/
theorem cliffordSpin2_projection_eq_one_iff
    (rotor : CliffordSpin2) :
    cliffordSpin2ToMatrixSO2Projection rotor = 1 ↔
      rotor = 1 ∨ rotor = cliffordSpin2MinusOne := by
  constructor
  · intro hKernel
    have hFiber :
        cliffordSpin2ToMatrixSO2Projection rotor =
          cliffordSpin2ToMatrixSO2Projection 1 := by
      simpa using hKernel
    have hCases :=
      (cliffordSpin2ToMatrixSO2Projection_eq_iff rotor 1).1 hFiber
    simpa [cliffordSpin2MinusOne] using hCases
  · rintro (rfl | rfl)
    · simp
    · exact cliffordSpin2MinusOne_projection

/-- The transported Clifford projection is an actual central double cover in the
abstract cocycle interface. -/
def cliffordSpin2MatrixCentralDoubleCover :
    CentralDoubleCoverData CliffordSpin2 MatrixSO2 where
  projection := cliffordSpin2ToMatrixSO2Projection
  kernel_central := by
    intro kernelElement hKernel spinElement
    exact cliffordSpin2_mul_comm kernelElement spinElement
  minusOne := cliffordSpin2MinusOne
  minusOne_mem_kernel := cliffordSpin2MinusOne_projection
  minusOne_ne_one := cliffordSpin2MinusOne_ne_one
  minusOne_sq := cliffordSpin2MinusOne_sq
  kernel_dichotomy := by
    intro rotor hKernel
    exact (cliffordSpin2_projection_eq_one_iff rotor).1 hKernel

/-- Diagonal central element in `CliffordSpin2 × U(1)`. -/
def cliffordSpin2DiagonalMinusOne : CliffordSpin2 × Circle :=
  (cliffordSpin2MinusOne, -1)

/-- Normal diagonal subgroup generated by the simultaneous Spin and phase signs. -/
def cliffordSpin2DiagonalSubgroup : Subgroup (CliffordSpin2 × Circle) :=
  Subgroup.closure {cliffordSpin2DiagonalMinusOne}

/-- Concrete algebraic rank-two SpinC group. -/
abbrev CliffordSpinC2 :=
  (CliffordSpin2 × Circle) ⧸ cliffordSpin2DiagonalSubgroup

/-- Exact diagonal quotient data for the Clifford rank-two model. -/
def cliffordSpinC2DiagonalQuotientData :
    SpinCDiagonalQuotientData CliffordSpin2 Circle CliffordSpinC2 where
  quotient := QuotientGroup.mk' cliffordSpin2DiagonalSubgroup
  spinMinusOne := cliffordSpin2MinusOne
  phaseMinusOne := -1
  diagonalMinusOne_killed := by
    change
      ((cliffordSpin2DiagonalMinusOne : CliffordSpin2 × Circle) :
        CliffordSpinC2) = 1
    exact (QuotientGroup.eq_one_iff cliffordSpin2DiagonalMinusOne).2
      (Subgroup.subset_closure (by simp [cliffordSpin2DiagonalMinusOne]))

/-- The algebraic diagonal quotient map is surjective. -/
theorem cliffordSpinC2DiagonalQuotient_surjective :
    Function.Surjective cliffordSpinC2DiagonalQuotientData.quotient :=
  QuotientGroup.mk'_surjective cliffordSpin2DiagonalSubgroup

/-- Specialized SpinC cocycle theorem for the actual Clifford-valued rank-two
Spin cover. Matching the trivial/nontrivial Spin and determinant-root defects
makes the diagonal quotient transitions satisfy the Čech cocycle law. -/
theorem matching_cliffordSpin2_defects_implies_spinCCocycle
    {Index : Type u}
    (orientedCocycle : TransitionCocycle Index MatrixSO2)
    (spinLift : ChosenTransitionLift
      cliffordSpin2MatrixCentralDoubleCover.toCentralCoverData orientedCocycle)
    (determinantLine : TransitionCocycle Index Circle)
    (rootChoice : SquareRootTransitionChoice determinantLine)
    (hMatch : ∀ i j k,
      liftDefect cliffordSpin2MatrixCentralDoubleCover.toCentralCoverData
          orientedCocycle spinLift i j k = 1 ↔
        phaseDefect rootChoice.root i j k = 1) :
    ∀ i j k,
      spinCTransition cliffordSpin2MatrixCentralDoubleCover orientedCocycle
          spinLift rootChoice.root cliffordSpinC2DiagonalQuotientData j k *
        spinCTransition cliffordSpin2MatrixCentralDoubleCover orientedCocycle
          spinLift rootChoice.root cliffordSpinC2DiagonalQuotientData i j =
      spinCTransition cliffordSpin2MatrixCentralDoubleCover orientedCocycle
        spinLift rootChoice.root cliffordSpinC2DiagonalQuotientData i k := by
  exact matching_squareRoot_defects_implies_spinCCocycle
    cliffordSpin2MatrixCentralDoubleCover orientedCocycle spinLift
    determinantLine rootChoice circleTwoTorsionPhaseData
    cliffordSpinC2DiagonalQuotientData rfl rfl hMatch

/-- Exact progress boundary after promoting the algebraic Clifford bridge to the
central-double-cover and SpinC diagonal-quotient interfaces. -/
structure CliffordSpin2DoubleCoverStatus where
  cliffordSpinGroupCommutativityProved : Prop
  distinguishedCentralSignConstructed : Prop
  exactProjectionKernelProved : Prop
  centralDoubleCoverPackaged : Prop
  spinCDiagonalSubgroupConstructed : Prop
  spinCDiagonalQuotientConstructed : Prop
  spinCDiagonalQuotientSurjective : Prop
  spinCCocycleDefectCancellationProved : Prop
  smoothCoveringMapProved : Prop
  principalSpinCBundleConstructed : Prop

/-- Closure of the geometric rank-two Clifford SpinC double-cover stage. -/
def cliffordSpin2DoubleCoverClosed
    (s : CliffordSpin2DoubleCoverStatus) : Prop :=
  s.cliffordSpinGroupCommutativityProved /\
  s.distinguishedCentralSignConstructed /\
  s.exactProjectionKernelProved /\
  s.centralDoubleCoverPackaged /\
  s.spinCDiagonalSubgroupConstructed /\
  s.spinCDiagonalQuotientConstructed /\
  s.spinCDiagonalQuotientSurjective /\
  s.spinCCocycleDefectCancellationProved /\
  s.smoothCoveringMapProved /\
  s.principalSpinCBundleConstructed

/-- The exact algebraic group extension still does not supply a smooth principal
SpinC bundle over the Janus frame bundle. -/
theorem missing_principal_spinC_bundle_blocks_geometric_stage
    (s : CliffordSpin2DoubleCoverStatus)
    (hMissing : Not s.principalSpinCBundleConstructed) :
    Not (cliffordSpin2DoubleCoverClosed s) := by
  intro hClosed
  exact hMissing hClosed.2.2.2.2.2.2.2.2.2

end

end P0EFTJanusCliffordSpin2DoubleCover
end JanusFormal
