import JanusFormal.Branches.FundamentalGeometryPEJetUniversality.Gates.P0EFTJanusSecondJetNormalForm

namespace JanusFormal
namespace P0EFTJanusConcreteSecondJetChainRule

set_option autoImplicit false

universe u v w

open P0EFTJanusSecondJetNormalForm

/-- Algebraic two-jet of a map at a fixed source and target point. The fields are
only the first and second Taylor coefficients; linearity and symmetry are tracked
separately when needed. -/
@[ext]
structure MapTwoJet (Source : Type u) (Target : Type v) where
  first : Source → Target
  second : Source → Source → Target

/-- Formal second-order chain rule for precomposition. For actual smooth maps
this is the Taylor-coefficient formula

`D²(f ∘ phi)(x,y) = D²f(Dphi x,Dphi y) + Df(D²phi(x,y))`.
-/
def precomposeTwoJet
    {Source : Type u}
    {Target : Type v}
    [Add Target]
    (mapJet : MapTwoJet Source Target)
    (sourceJet : MapTwoJet Source Source) :
    MapTwoJet Source Target where
  first x := mapJet.first (sourceJet.first x)
  second x y :=
    mapJet.second (sourceJet.first x) (sourceJet.first y) +
      mapJet.first (sourceJet.second x y)

/-- Source two-jet with identity linear part and prescribed quadratic part. -/
def quadraticSourceTwoJet
    {Source : Type u}
    (change : Source → Source → Source) :
    MapTwoJet Source Source where
  first := id
  second := change

/-- Split form of a normalized immersion two-jet. -/
abbrev SplitImmersionSecondJet (Tangent : Type u) (Normal : Type v) :=
  SecondJetData (Tangent → Tangent → Tangent)
    (Tangent → Tangent → Normal)

/-- After first-order normalization, the immersion derivative is the standard
inclusion `x ↦ (x,0)` and the quadratic term splits into tangent and normal
components. -/
def normalizedImmersionTwoJet
    {Tangent : Type u}
    {Normal : Type v}
    [Zero Normal]
    (jet : SplitImmersionSecondJet Tangent Normal) :
    MapTwoJet Tangent (Tangent × Normal) where
  first x := (x, 0)
  second x y :=
    (jet.tangentialQuadratic x y, jet.normalQuadratic x y)

/-- The normalized immersion encoding is injective: its second Taylor
coefficient remembers both split quadratic tensors. -/
theorem normalizedImmersionTwoJet_injective
    {Tangent : Type u}
    {Normal : Type v}
    [Zero Normal] :
    Function.Injective
      (normalizedImmersionTwoJet (Tangent := Tangent) (Normal := Normal)) := by
  intro first second hEqual
  apply SecondJetData.ext
  · funext x y
    have hSecond := congrArg MapTwoJet.second hEqual
    have hAt := congrFun (congrFun hSecond x) y
    exact congrArg Prod.fst hAt
  · funext x y
    have hSecond := congrArg MapTwoJet.second hEqual
    have hAt := congrFun (congrFun hSecond x) y
    exact congrArg Prod.snd hAt

/-- Concrete second-order chain-rule calculation after first-order immersion
normalization. A quadratic source reparametrization adds its quadratic tensor to
the tangent-valued part and leaves the normal-valued part unchanged. -/
theorem quadratic_precomposition_formula
    {Tangent : Type u}
    {Normal : Type v}
    [Add Tangent]
    [AddMonoid Normal]
    (change : Tangent → Tangent → Tangent)
    (jet : SplitImmersionSecondJet Tangent Normal) :
    precomposeTwoJet
        (normalizedImmersionTwoJet jet)
        (quadraticSourceTwoJet change) =
      normalizedImmersionTwoJet (sourceQuadraticChange change jet) := by
  apply MapTwoJet.ext
  · funext x
    rfl
  · funext x y
    simp [precomposeTwoJet, normalizedImmersionTwoJet,
      quadraticSourceTwoJet, sourceQuadraticChange]

/-- The explicit quadratic reparametrization `-Q_tangent` reaches the canonical
normal slice at the level of the actual two-jet chain-rule formula. -/
theorem concrete_change_reaches_normal_form
    {Tangent : Type u}
    {Normal : Type v}
    [AddGroup Tangent]
    [AddMonoid Normal]
    (jet : SplitImmersionSecondJet Tangent Normal) :
    precomposeTwoJet
        (normalizedImmersionTwoJet jet)
        (quadraticSourceTwoJet (-jet.tangentialQuadratic)) =
      normalizedImmersionTwoJet (normalForm jet) := by
  calc
    precomposeTwoJet
        (normalizedImmersionTwoJet jet)
        (quadraticSourceTwoJet (-jet.tangentialQuadratic)) =
      normalizedImmersionTwoJet
        (sourceQuadraticChange (-jet.tangentialQuadratic) jet) :=
      quadratic_precomposition_formula _ _
    _ = normalizedImmersionTwoJet (normalForm jet) :=
      congrArg normalizedImmersionTwoJet
        (chosen_change_reaches_normal_form jet)

/-- Equivalence generated by actual quadratic precomposition of normalized
immersion two-jets. -/
def EquivalentByQuadraticPrecomposition
    {Tangent : Type u}
    {Normal : Type v}
    [Add Tangent]
    [AddMonoid Normal]
    (first second : SplitImmersionSecondJet Tangent Normal) : Prop :=
  ∃ change : Tangent → Tangent → Tangent,
    precomposeTwoJet
        (normalizedImmersionTwoJet first)
        (quadraticSourceTwoJet change) =
      normalizedImmersionTwoJet second

/-- The concrete chain-rule orbit relation agrees exactly with the additive
source-change relation used by the abstract normal-form gate. -/
theorem concrete_equivalent_iff_abstract_equivalent
    {Tangent : Type u}
    {Normal : Type v}
    [AddGroup Tangent]
    [AddMonoid Normal]
    (first second : SplitImmersionSecondJet Tangent Normal) :
    EquivalentByQuadraticPrecomposition first second ↔
      EquivalentBySourceChange first second := by
  constructor
  · rintro ⟨change, hChange⟩
    refine ⟨change, ?_⟩
    apply normalizedImmersionTwoJet_injective
    calc
      normalizedImmersionTwoJet (sourceQuadraticChange change first) =
          precomposeTwoJet
            (normalizedImmersionTwoJet first)
            (quadraticSourceTwoJet change) :=
        (quadratic_precomposition_formula change first).symm
      _ = normalizedImmersionTwoJet second := hChange
  · rintro ⟨change, hChange⟩
    refine ⟨change, ?_⟩
    calc
      precomposeTwoJet
          (normalizedImmersionTwoJet first)
          (quadraticSourceTwoJet change) =
        normalizedImmersionTwoJet (sourceQuadraticChange change first) :=
        quadratic_precomposition_formula change first
      _ = normalizedImmersionTwoJet second :=
        congrArg normalizedImmersionTwoJet hChange

/-- Concrete low-order jet quotient: two normalized immersion two-jets differ by
a quadratic source reparametrization exactly when their normal quadratic tensors
agree. -/
theorem concrete_equivalent_iff_normal_eq
    {Tangent : Type u}
    {Normal : Type v}
    [AddGroup Tangent]
    [AddMonoid Normal]
    (first second : SplitImmersionSecondJet Tangent Normal) :
    EquivalentByQuadraticPrecomposition first second ↔
      first.normalQuadratic = second.normalQuadratic := by
  rw [concrete_equivalent_iff_abstract_equivalent]
  exact equivalent_iff_normal_eq first second

/-- Symmetry condition on a two-covariant tensor. -/
def IsSymmetricTensor
    {Source : Type u}
    {Target : Type v}
    (tensor : Source → Source → Target) : Prop :=
  ∀ x y, tensor x y = tensor y x

/-- Symmetry of both quadratic components of a split immersion jet. -/
def IsSymmetricSplitJet
    {Tangent : Type u}
    {Normal : Type v}
    (jet : SplitImmersionSecondJet Tangent Normal) : Prop :=
  IsSymmetricTensor jet.tangentialQuadratic ∧
    IsSymmetricTensor jet.normalQuadratic

/-- Quadratic source changes preserve the symmetric-tensor locus. -/
theorem source_change_preserves_symmetry
    {Tangent : Type u}
    {Normal : Type v}
    [Add Tangent]
    (change : Tangent → Tangent → Tangent)
    (jet : SplitImmersionSecondJet Tangent Normal)
    (hJet : IsSymmetricSplitJet jet)
    (hChange : IsSymmetricTensor change) :
    IsSymmetricSplitJet (sourceQuadraticChange change jet) := by
  constructor
  · intro x y
    change jet.tangentialQuadratic x y + change x y =
      jet.tangentialQuadratic y x + change y x
    rw [hJet.1 x y, hChange x y]
  · exact hJet.2

section ResidualFrameAction

variable {TangentGroup : Type u}
variable {NormalGroup : Type v}
variable {Tangent : Type w}
variable {Normal : Type*}
variable [Group TangentGroup]
variable [Group NormalGroup]
variable [MulAction TangentGroup Tangent]
variable [MulAction NormalGroup Normal]

/-- Residual tangent-frame action on a tangent-valued symmetric two-tensor. -/
def actOnTangentialTensor
    (frame : TangentGroup)
    (tensor : Tangent → Tangent → Tangent) :
    Tangent → Tangent → Tangent :=
  fun x y =>
    frame • tensor (frame⁻¹ • x) (frame⁻¹ • y)

/-- Residual `tangent frame × normal frame` action on a normal-valued symmetric
two-tensor, the transformation law of the second fundamental form. -/
def actOnNormalTensor
    (frame : TangentGroup × NormalGroup)
    (tensor : Tangent → Tangent → Normal) :
    Tangent → Tangent → Normal :=
  fun x y =>
    frame.2 • tensor (frame.1⁻¹ • x) (frame.1⁻¹ • y)

/-- Residual frame action on the full split quadratic jet. -/
def actOnSplitImmersionJet
    (frame : TangentGroup × NormalGroup)
    (jet : SplitImmersionSecondJet Tangent Normal) :
    SplitImmersionSecondJet Tangent Normal where
  tangentialQuadratic :=
    actOnTangentialTensor frame.1 jet.tangentialQuadratic
  normalQuadratic :=
    actOnNormalTensor frame jet.normalQuadratic

@[simp]
theorem actOnTangentialTensor_one
    (tensor : Tangent → Tangent → Tangent) :
    actOnTangentialTensor (1 : TangentGroup) tensor = tensor := by
  funext x y
  simp [actOnTangentialTensor]

@[simp]
theorem actOnTangentialTensor_mul
    (first second : TangentGroup)
    (tensor : Tangent → Tangent → Tangent) :
    actOnTangentialTensor (first * second) tensor =
      actOnTangentialTensor first
        (actOnTangentialTensor second tensor) := by
  funext x y
  simp [actOnTangentialTensor, mul_smul]

@[simp]
theorem actOnNormalTensor_one
    (tensor : Tangent → Tangent → Normal) :
    actOnNormalTensor
        (1 : TangentGroup × NormalGroup) tensor = tensor := by
  funext x y
  simp [actOnNormalTensor]

@[simp]
theorem actOnNormalTensor_mul
    (first second : TangentGroup × NormalGroup)
    (tensor : Tangent → Tangent → Normal) :
    actOnNormalTensor (first * second) tensor =
      actOnNormalTensor first (actOnNormalTensor second tensor) := by
  funext x y
  simp [actOnNormalTensor, mul_smul]

@[simp]
theorem actOnSplitImmersionJet_one
    (jet : SplitImmersionSecondJet Tangent Normal) :
    actOnSplitImmersionJet
        (1 : TangentGroup × NormalGroup) jet = jet := by
  apply SecondJetData.ext
  · exact actOnTangentialTensor_one jet.tangentialQuadratic
  · exact actOnNormalTensor_one jet.normalQuadratic

@[simp]
theorem actOnSplitImmersionJet_mul
    (first second : TangentGroup × NormalGroup)
    (jet : SplitImmersionSecondJet Tangent Normal) :
    actOnSplitImmersionJet (first * second) jet =
      actOnSplitImmersionJet first
        (actOnSplitImmersionJet second jet) := by
  apply SecondJetData.ext
  · exact actOnTangentialTensor_mul first.1 second.1
      jet.tangentialQuadratic
  · exact actOnNormalTensor_mul first second jet.normalQuadratic

/-- The residual product action preserves symmetry of the second fundamental
form tensor. -/
theorem normal_tensor_action_preserves_symmetry
    (frame : TangentGroup × NormalGroup)
    (tensor : Tangent → Tangent → Normal)
    (hSymmetric : IsSymmetricTensor tensor) :
    IsSymmetricTensor (actOnNormalTensor frame tensor) := by
  intro x y
  simp only [actOnNormalTensor]
  rw [hSymmetric]

end ResidualFrameAction

section CompatibleResidualFrameAction

variable {TangentGroup : Type u}
variable {NormalGroup : Type v}
variable {Tangent : Type w}
variable {Normal : Type*}
variable [Group TangentGroup]
variable [Group NormalGroup]
variable [AddGroup Tangent]
variable [DistribMulAction TangentGroup Tangent]
variable [MulAction NormalGroup Normal]

/-- Residual frame transformations normalize the quadratic source-change action.
This is the concrete semidirect-product compatibility needed to descend the
residual frame action to the quotient represented by the normal tensor. -/
theorem residual_action_commutes_with_quadratic_source_change
    (frame : TangentGroup × NormalGroup)
    (change : Tangent → Tangent → Tangent)
    (jet : SplitImmersionSecondJet Tangent Normal) :
    actOnSplitImmersionJet frame
        (sourceQuadraticChange change jet) =
      sourceQuadraticChange
        (actOnTangentialTensor frame.1 change)
        (actOnSplitImmersionJet frame jet) := by
  apply SecondJetData.ext
  · funext x y
    simp [actOnSplitImmersionJet, actOnTangentialTensor,
      sourceQuadraticChange, smul_add]
  · rfl

/-- The zero-tangential normal slice is stable under the residual frame group. -/
theorem normal_form_is_residual_equivariant
    (frame : TangentGroup × NormalGroup)
    (jet : SplitImmersionSecondJet Tangent Normal) :
    actOnSplitImmersionJet frame (normalForm jet) =
      normalForm (actOnSplitImmersionJet frame jet) := by
  apply SecondJetData.ext
  · funext x y
    simp [actOnSplitImmersionJet, actOnTangentialTensor, normalForm]
  · rfl

end CompatibleResidualFrameAction

/-- Boundary between the concrete low-order chain-rule theorem and the full
geometric immersion-jet isomorphism theorem. -/
structure ConcreteSecondJetGeometricStatus where
  secondOrderChainRuleEncoded : Prop
  normalizedInclusionEncodingInjective : Prop
  concreteQuadraticOrbitClassified : Prop
  symmetricTensorLocusPreserved : Prop
  residualTangentNormalActionConstructed : Prop
  residualActionDescendsToNormalTensor : Prop
  adaptedOrthogonalFramesConstructed : Prop
  normalTensorIdentifiedWithGeometricSecondFundamentalForm : Prop
  smoothFiniteDimensionalJetBundleConstructed : Prop

/-- Closure of the genuine geometric second-immersion-jet theorem. -/
def concreteSecondJetGeometricClosed
    (s : ConcreteSecondJetGeometricStatus) : Prop :=
  s.secondOrderChainRuleEncoded /\
  s.normalizedInclusionEncodingInjective /\
  s.concreteQuadraticOrbitClassified /\
  s.symmetricTensorLocusPreserved /\
  s.residualTangentNormalActionConstructed /\
  s.residualActionDescendsToNormalTensor /\
  s.adaptedOrthogonalFramesConstructed /\
  s.normalTensorIdentifiedWithGeometricSecondFundamentalForm /\
  s.smoothFiniteDimensionalJetBundleConstructed

/-- The algebraic chain-rule quotient still does not construct adapted
orthonormal frames for an actual Riemannian immersion. -/
theorem missing_adapted_frames_blocks_geometric_second_jet_theorem
    (s : ConcreteSecondJetGeometricStatus)
    (hMissing : Not s.adaptedOrthogonalFramesConstructed) :
    Not (concreteSecondJetGeometricClosed s) := by
  intro hClosed
  exact hMissing hClosed.2.2.2.2.2.2.1

end P0EFTJanusConcreteSecondJetChainRule
end JanusFormal
