import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusScalarAbstractLagrangianBoundary4D

/-!
# Hilbert Green cores with dense, not surjective, smooth trace

A smooth trace map into an infinite-dimensional L2 boundary space cannot be
surjective: its image consists of smooth representatives.  The correct analytic
statement is density of the smooth trace range, followed by surjectivity only
after graph completion and a boundary extension theorem.

This file separates these levels.

* `CanonicalScalarHilbertGreenCore` has a dense smooth boundary range.
* The graph completion and continuous boundary trace require only a graph bound.
* `CanonicalScalarCompletedBoundaryTripleData` adds surjectivity of the completed
  trace and injectivity of the completed ambient inclusion.
* Closed Lagrangian domains are then defined directly inside that completed
  maximal graph; symmetry and boundary-adjoint maximality follow exactly as in a
  boundary triple.

This is the physically correct route for the infinite-dimensional Janus throat.
-/

namespace JanusFormal
namespace P0EFTJanusMappingTorusScalarHilbertGreenCoreCompletion4D

set_option autoImplicit false
noncomputable section

open Set Topology
open P0EFTJanusMappingTorusScalarHilbertBoundarySymplectic4D
open P0EFTJanusMappingTorusScalarAbstractLagrangianBoundary4D

universe u v w

variable {Domain : Type u} {Ambient : Type v} {Trace : Type w}
  [AddCommGroup Domain] [Module Real Domain]
  [NormedAddCommGroup Ambient] [InnerProductSpace Real Ambient]
  [CompleteSpace Ambient]
  [NormedAddCommGroup Trace] [InnerProductSpace Real Trace]
  [CompleteSpace Trace]

/-- Smooth Hilbert Green core with dense boundary trace range. -/
structure CanonicalScalarHilbertGreenCore where
  inclusion : Domain →ₗ[Real] Ambient
  operator : Domain →ₗ[Real] Ambient
  boundaryTrace : Domain →ₗ[Real]
    CanonicalScalarHilbertBoundaryDatum (Trace := Trace)
  boundary_dense : DenseRange boundaryTrace
  green_identity : ∀ first second : Domain,
    inner Real (operator first) (inclusion second) -
        inner Real (inclusion first) (operator second) =
      2 * canonicalScalarHilbertBoundarySymplecticForm
        (boundaryTrace first) (boundaryTrace second)

/-- Algebraic graph map of a smooth Green core. -/
def canonicalScalarGreenCoreGraphLinearMap
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    Domain →ₗ[Real] Ambient × Ambient where
  toFun field := (core.inclusion field, core.operator field)
  map_add' first second := by simp
  map_smul' scalar field := by simp

/-- Closed graph relation generated by the smooth core. -/
def canonicalScalarGreenCoreGraphSubmodule
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    Submodule Real (Ambient × Ambient) :=
  (LinearMap.range (canonicalScalarGreenCoreGraphLinearMap core)).topologicalClosure

/-- Completed maximal graph of the smooth Green core. -/
abbrev CanonicalScalarGreenCoreGraphSpace
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :=
  canonicalScalarGreenCoreGraphSubmodule core

/-- Dense smooth graph inclusion. -/
def canonicalScalarGreenCoreToGraph
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    Domain →ₗ[Real] CanonicalScalarGreenCoreGraphSpace core where
  toFun field :=
    ⟨canonicalScalarGreenCoreGraphLinearMap core field,
      (LinearMap.range
        (canonicalScalarGreenCoreGraphLinearMap core)).le_topologicalClosure
        (LinearMap.mem_range_self
          (canonicalScalarGreenCoreGraphLinearMap core) field)⟩
  map_add' first second := Subtype.ext (map_add _ _ _)
  map_smul' scalar field := Subtype.ext (map_smul _ _ _)

/-- Smooth graph core is dense by construction. -/
theorem canonicalScalarGreenCoreToGraph_denseRange
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    DenseRange (canonicalScalarGreenCoreToGraph core) := by
  simp only [DenseRange]
  rw [Subtype.dense_iff]
  let graph := canonicalScalarGreenCoreGraphLinearMap core
  have hRange :
      Subtype.val '' Set.range (canonicalScalarGreenCoreToGraph core) =
        (LinearMap.range graph : Set (Ambient × Ambient)) := by
    ext value
    constructor
    · rintro ⟨lifted, ⟨field, rfl⟩, rfl⟩
      exact ⟨field, rfl⟩
    · rintro ⟨field, rfl⟩
      exact ⟨canonicalScalarGreenCoreToGraph core field,
        ⟨field, rfl⟩, rfl⟩
  change closure (LinearMap.range graph : Set (Ambient × Ambient)) ⊆
    closure (Subtype.val '' Set.range (canonicalScalarGreenCoreToGraph core))
  rw [hRange]

/-- Completeness of the closed graph relation. -/
@[implicit_reducible]
def canonicalScalarGreenCoreGraphCompleteSpace
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    CompleteSpace (CanonicalScalarGreenCoreGraphSpace core) := by
  letI : CompleteSpace (Ambient × Ambient) := inferInstance
  exact Submodule.topologicalClosure.completeSpace
    (LinearMap.range (canonicalScalarGreenCoreGraphLinearMap core))

/-- Ambient coordinate on the completed graph. -/
def canonicalScalarGreenCoreGraphInclusion
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    CanonicalScalarGreenCoreGraphSpace core →L[Real] Ambient :=
  (ContinuousLinearMap.fst Real Ambient Ambient).comp
    (canonicalScalarGreenCoreGraphSubmodule core).subtypeL

/-- Operator coordinate on the completed graph. -/
def canonicalScalarGreenCoreGraphOperator
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) :
    CanonicalScalarGreenCoreGraphSpace core →L[Real] Ambient :=
  (ContinuousLinearMap.snd Real Ambient Ambient).comp
    (canonicalScalarGreenCoreGraphSubmodule core).subtypeL

@[simp] theorem canonicalScalarGreenCoreGraphInclusion_smooth
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (field : Domain) :
    canonicalScalarGreenCoreGraphInclusion core
        (canonicalScalarGreenCoreToGraph core field) =
      core.inclusion field :=
  rfl

@[simp] theorem canonicalScalarGreenCoreGraphOperator_smooth
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (field : Domain) :
    canonicalScalarGreenCoreGraphOperator core
        (canonicalScalarGreenCoreToGraph core field) =
      core.operator field :=
  rfl

/-- Graph bound for a dense smooth trace. -/
structure HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace)) where
  constant : Real
  nonnegative : 0 ≤ constant
  bound : ∀ field : Domain,
    ‖core.boundaryTrace field‖ ≤
      constant * ‖canonicalScalarGreenCoreToGraph core field‖

/-- Unique continuous paired trace on the completed maximal graph. -/
def canonicalScalarGreenCoreCompletedBoundaryTrace
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core) :
    CanonicalScalarGreenCoreGraphSpace core →L[Real]
      CanonicalScalarHilbertBoundaryDatum (Trace := Trace) :=
  core.boundaryTrace.extendOfNorm (canonicalScalarGreenCoreToGraph core)

/-- Completed trace agrees with the smooth trace. -/
theorem canonicalScalarGreenCoreCompletedBoundaryTrace_smooth
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core)
    (field : Domain) :
    canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound
        (canonicalScalarGreenCoreToGraph core field) =
      core.boundaryTrace field :=
  LinearMap.extendOfNorm_eq
    (canonicalScalarGreenCoreToGraph_denseRange core)
    ⟨traceBound.constant, traceBound.bound⟩ field

/-- Uniform bound on the completed trace. -/
theorem canonicalScalarGreenCoreCompletedBoundaryTrace_norm_le
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core)
    (field : CanonicalScalarGreenCoreGraphSpace core) :
    ‖canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound field‖ ≤
      traceBound.constant * ‖field‖ :=
  LinearMap.norm_extendOfNorm_apply_le
    (canonicalScalarGreenCoreToGraph_denseRange core)
    traceBound.constant traceBound.bound field

/-- Completed boundary Green pairing. -/
def canonicalScalarGreenCoreCompletedBoundaryPairing
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core)
    (first second : CanonicalScalarGreenCoreGraphSpace core) : Real :=
  2 * canonicalScalarHilbertBoundarySymplecticForm
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound first)
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound second)

private theorem canonicalScalarGreenCoreCompletedGreenIdentity_left_smooth
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core)
    (test : Domain) (first : CanonicalScalarGreenCoreGraphSpace core) :
    inner Real (canonicalScalarGreenCoreGraphOperator core first)
          (canonicalScalarGreenCoreGraphInclusion core
            (canonicalScalarGreenCoreToGraph core test)) -
        inner Real (canonicalScalarGreenCoreGraphInclusion core first)
          (canonicalScalarGreenCoreGraphOperator core
            (canonicalScalarGreenCoreToGraph core test)) =
      canonicalScalarGreenCoreCompletedBoundaryPairing
        core traceBound first (canonicalScalarGreenCoreToGraph core test) := by
  let smooth := canonicalScalarGreenCoreToGraph core
  let good : Set (CanonicalScalarGreenCoreGraphSpace core) :=
    {candidate |
      inner Real (canonicalScalarGreenCoreGraphOperator core candidate)
            (canonicalScalarGreenCoreGraphInclusion core (smooth test)) -
          inner Real (canonicalScalarGreenCoreGraphInclusion core candidate)
            (canonicalScalarGreenCoreGraphOperator core (smooth test)) =
        canonicalScalarGreenCoreCompletedBoundaryPairing
          core traceBound candidate (smooth test)}
  have hGoodClosed : IsClosed good := by
    dsimp [good]
    apply isClosed_eq
    · fun_prop
    · unfold canonicalScalarGreenCoreCompletedBoundaryPairing
      unfold canonicalScalarHilbertBoundarySymplecticForm
      fun_prop
  have hRange : Set.range smooth ⊆ good := by
    rintro candidate ⟨field, rfl⟩
    change inner Real (core.operator field) (core.inclusion test) -
        inner Real (core.inclusion field) (core.operator test) =
      2 * canonicalScalarHilbertBoundarySymplecticForm
        (canonicalScalarGreenCoreCompletedBoundaryTrace
          core traceBound (smooth field))
        (canonicalScalarGreenCoreCompletedBoundaryTrace
          core traceBound (smooth test))
    rw [canonicalScalarGreenCoreCompletedBoundaryTrace_smooth,
      canonicalScalarGreenCoreCompletedBoundaryTrace_smooth]
    exact core.green_identity field test
  have hClosure : closure (Set.range smooth) = Set.univ :=
    (canonicalScalarGreenCoreToGraph_denseRange core).closure_range
  have hFirstClosure : first ∈ closure (Set.range smooth) := by
    rw [hClosure]
    trivial
  exact (closure_minimal hRange hGoodClosed) hFirstClosure

/-- Exact Green identity on the full completed maximal graph. -/
theorem canonicalScalarGreenCoreCompletedGreenIdentity
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core)
    (first second : CanonicalScalarGreenCoreGraphSpace core) :
    inner Real (canonicalScalarGreenCoreGraphOperator core first)
          (canonicalScalarGreenCoreGraphInclusion core second) -
        inner Real (canonicalScalarGreenCoreGraphInclusion core first)
          (canonicalScalarGreenCoreGraphOperator core second) =
      canonicalScalarGreenCoreCompletedBoundaryPairing
        core traceBound first second := by
  let smooth := canonicalScalarGreenCoreToGraph core
  let good : Set (CanonicalScalarGreenCoreGraphSpace core) :=
    {candidate |
      inner Real (canonicalScalarGreenCoreGraphOperator core first)
            (canonicalScalarGreenCoreGraphInclusion core candidate) -
          inner Real (canonicalScalarGreenCoreGraphInclusion core first)
            (canonicalScalarGreenCoreGraphOperator core candidate) =
        canonicalScalarGreenCoreCompletedBoundaryPairing
          core traceBound first candidate}
  have hGoodClosed : IsClosed good := by
    dsimp [good]
    apply isClosed_eq
    · fun_prop
    · unfold canonicalScalarGreenCoreCompletedBoundaryPairing
      unfold canonicalScalarHilbertBoundarySymplecticForm
      fun_prop
  have hRange : Set.range smooth ⊆ good := by
    rintro candidate ⟨test, rfl⟩
    exact canonicalScalarGreenCoreCompletedGreenIdentity_left_smooth
      core traceBound test first
  have hClosure : closure (Set.range smooth) = Set.univ :=
    (canonicalScalarGreenCoreToGraph_denseRange core).closure_range
  have hSecondClosure : second ∈ closure (Set.range smooth) := by
    rw [hClosure]
    trivial
  exact (closure_minimal hRange hGoodClosed) hSecondClosure

/-- Correct completed boundary-triple input: surjectivity is required only after
completion, and the maximal graph inclusion is single-valued. -/
structure CanonicalScalarCompletedBoundaryTripleData
    (core : CanonicalScalarHilbertGreenCore
      (Domain := Domain) (Ambient := Ambient) (Trace := Trace))
    (traceBound : HasCanonicalScalarHilbertGreenCoreBoundaryGraphBound core) where
  boundary_surjective : Function.Surjective
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound)
  inclusion_injective : Function.Injective
    (canonicalScalarGreenCoreGraphInclusion core)

namespace CanonicalScalarCompletedBoundaryTripleData

/-- Closed maximal graph domain. -/
abbrev MaximalDomain
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound) :=
  CanonicalScalarGreenCoreGraphSpace core

/-- Pullback of a closed Lagrangian condition to the completed maximal graph. -/
def lagrangianDomainSubmodule
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    Submodule Real triple.MaximalDomain :=
  condition.subspace.comap
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound).toLinearMap

/-- Every completed-core Lagrangian domain is closed. -/
theorem lagrangianDomain_isClosed
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    IsClosed (triple.lagrangianDomainSubmodule condition :
      Set triple.MaximalDomain) := by
  change IsClosed
    ((canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound) ⁻¹'
      (condition.subspace :
        Set (CanonicalScalarHilbertBoundaryDatum (Trace := Trace))))
  exact condition.isClosed.preimage
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound).continuous

/-- Ambient inclusion of a completed-core Lagrangian domain. -/
def lagrangianInclusion
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    triple.lagrangianDomainSubmodule condition →L[Real] Ambient :=
  (canonicalScalarGreenCoreGraphInclusion core).comp
    (triple.lagrangianDomainSubmodule condition).subtypeL

/-- Operator on a completed-core Lagrangian domain. -/
def lagrangianOperator
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    triple.lagrangianDomainSubmodule condition →L[Real] Ambient :=
  (canonicalScalarGreenCoreGraphOperator core).comp
    (triple.lagrangianDomainSubmodule condition).subtypeL

/-- Ambient inclusion remains injective. -/
theorem lagrangianInclusion_injective
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    Function.Injective (triple.lagrangianInclusion condition) := by
  intro first second hEqual
  apply Subtype.ext
  exact triple.inclusion_injective hEqual

/-- Every completed-core Lagrangian realization is symmetric. -/
theorem lagrangianOperator_symmetric
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace)
    (first second : triple.lagrangianDomainSubmodule condition) :
    inner Real (triple.lagrangianOperator condition first)
          (triple.lagrangianInclusion condition second) =
      inner Real (triple.lagrangianInclusion condition first)
          (triple.lagrangianOperator condition second) := by
  have hBoundary := condition.pairing_eq_zero
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound first.1)
    (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound second.1)
    first.2 second.2
  have hGreen := canonicalScalarGreenCoreCompletedGreenIdentity
    core traceBound first.1 second.1
  unfold canonicalScalarGreenCoreCompletedBoundaryPairing at hGreen
  rw [hBoundary] at hGreen
  linarith

/-- Boundary-adjoint admissibility inside the completed maximal graph. -/
def lagrangianAdjointAdmissible
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace)
    (candidate : triple.MaximalDomain) : Prop :=
  ∀ test : triple.lagrangianDomainSubmodule condition,
    canonicalScalarHilbertBoundarySymplecticForm
      (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound candidate)
      (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound test.1) = 0

/-- Boundary-adjoint maximality of the completed-core Lagrangian domain. -/
theorem lagrangianAdjointAdmissible_iff_mem
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace)
    (candidate : triple.MaximalDomain) :
    triple.lagrangianAdjointAdmissible condition candidate ↔
      candidate ∈ triple.lagrangianDomainSubmodule condition := by
  constructor
  · intro hCandidate
    have hOrthogonal :
        canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound candidate ∈
          canonicalScalarHilbertBoundarySymplecticOrthogonal
            condition.subspace := by
      intro testBoundary hTestBoundary
      obtain ⟨test, hTrace⟩ :=
        triple.boundary_surjective testBoundary
      have hTestDomain : test ∈
          triple.lagrangianDomainSubmodule condition := by
        change canonicalScalarGreenCoreCompletedBoundaryTrace
          core traceBound test ∈ condition.subspace
        rw [hTrace]
        exact hTestBoundary
      have hApplied := hCandidate ⟨test, hTestDomain⟩
      rw [hTrace] at hApplied
      exact hApplied
    rw [← condition.lagrangian]
    exact hOrthogonal
  · intro hCandidate test
    have hCandidateOrthogonal :
        canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound candidate ∈
          canonicalScalarHilbertBoundarySymplecticOrthogonal
            condition.subspace := by
      rw [condition.lagrangian]
      exact hCandidate
    exact hCandidateOrthogonal
      (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound test.1)
      test.2

/-- Completed-core Lagrangian boundary-adjoint domain. -/
def lagrangianAdjointDomain
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    Set triple.MaximalDomain :=
  {candidate | triple.lagrangianAdjointAdmissible condition candidate}

/-- Exact equality of boundary-adjoint and boundary-condition domains. -/
theorem lagrangianAdjointDomain_eq
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    triple.lagrangianAdjointDomain condition =
      (triple.lagrangianDomainSubmodule condition : Set triple.MaximalDomain) := by
  ext candidate
  exact triple.lagrangianAdjointAdmissible_iff_mem condition candidate

/-- Correct dense-core boundary-triple certificate. -/
theorem certificate
    (triple : CanonicalScalarCompletedBoundaryTripleData core traceBound)
    (condition : CanonicalScalarHilbertLagrangianBoundaryCondition Trace) :
    DenseRange (canonicalScalarGreenCoreToGraph core) ∧
      Function.Surjective
        (canonicalScalarGreenCoreCompletedBoundaryTrace core traceBound) ∧
      IsClosed (triple.lagrangianDomainSubmodule condition :
        Set triple.MaximalDomain) ∧
      (∀ first second : triple.lagrangianDomainSubmodule condition,
        inner Real (triple.lagrangianOperator condition first)
              (triple.lagrangianInclusion condition second) =
          inner Real (triple.lagrangianInclusion condition first)
              (triple.lagrangianOperator condition second)) ∧
      triple.lagrangianAdjointDomain condition =
        (triple.lagrangianDomainSubmodule condition : Set triple.MaximalDomain) :=
  ⟨canonicalScalarGreenCoreToGraph_denseRange core,
    triple.boundary_surjective,
    triple.lagrangianDomain_isClosed condition,
    triple.lagrangianOperator_symmetric condition,
    triple.lagrangianAdjointDomain_eq condition⟩

end CanonicalScalarCompletedBoundaryTripleData

end
end P0EFTJanusMappingTorusScalarHilbertGreenCoreCompletion4D
end JanusFormal
