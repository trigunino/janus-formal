import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMatterLLActualU1NoetherSubidentity4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusCompleteVariationPairedLinearBRSTBridge4D

/-!
# Actual U(1)^2 Noether identity from the paired linear BRST ghosts

This gate extracts exactly the two global abelian ghosts stored by the paired
linear BRST realization in `ProgramPCompleteVariation4D`.  It feeds those
same ghosts to the intrinsic generator `R_A(c) = dc`, identifies the resulting
one-forms with the potential components of the paired BRST differential, and
then transports the finite invariance and dynamic `B(dS) = 0` theorem for the
same restricted matter--LL action.

The intrinsic one-forms are not inserted into, or identified with, the
coordinate-valued gauge slot of the complete variation or D9.  Maxwell,
diagonal diffeomorphisms and the global Program-P Noether identity remain
outside this sectorial bridge.
-/

namespace JanusFormal
namespace P0EFTJanusMatterLLActualU1NoetherPairedLinearBRSTBridge4D

set_option autoImplicit false
noncomputable section

open scoped Manifold ContDiff
open MeasureTheory
open P0EFTJanusReflectionFixedThroat
open P0EFTJanusMappingTorusQuotient
open P0EFTJanusMappingTorusSmoothAtlasFrontier
open P0EFTJanusMappingTorusSmoothQuotientManifold
open P0EFTJanusMappingTorusSmoothFieldDescent4D
open P0EFTJanusMappingTorusSmoothGlobalFieldConfiguration4D
open P0EFTJanusMappingTorusAbelianGaugeBRST4D
open P0EFTJanusMappingTorusMatterGaugeNoetherOperator4D
open P0EFTJanusGlobalMatterMultipletActualEulerHessian4D
open P0EFTJanusMappingTorusDifferentialLLWeakEquation4D
open P0EFTJanusCommonPairedD9LinearBRSTBlock4D
open P0EFTJanusCompleteVariationPairedLinearBRSTBridge4D
open P0EFTJanusMatterLLActualU1NoetherSubidentity4D

variable (period : Real) (hPeriod : period ≠ 0)

private abbrev sphereData := reflectedSphereData period hPeriod
private abbrev EffectiveQuotient := MappingTorus (sphereData period hPeriod)
private abbrev EffectiveThroat := MappingTorus (fixedEquatorData period hPeriod)

local instance : ChartedSpace CoverModel (EffectiveQuotient period hPeriod) :=
  reflectedSphereQuotientChartedSpace period hPeriod

local instance : IsManifold coverModelWithCorners ω
    (EffectiveQuotient period hPeriod) :=
  reflectedSphereQuotient_isManifold period hPeriod

local instance : ChartedSpace ThroatCoverModel (EffectiveThroat period hPeriod) :=
  fixedThroatQuotientChartedSpace period hPeriod

local instance : IsManifold throatCoverModelWithCorners ω
    (EffectiveThroat period hPeriod) :=
  fixedThroatQuotient_isManifold period hPeriod

local instance : MeasurableSpace (EffectiveThroat period hPeriod) := borel _

local instance : BorelSpace (EffectiveThroat period hPeriod) where
  measurable_eq := rfl

/-- The two U(1) parameters are exactly the ghost pair stored in the complete
variation realization of the paired linear BRST state. -/
def completeVariationPairedU1Parameters
    (state : CommonPairedD9LinearBRSTBlock period hPeriod) :
    SmoothQuotientField period hPeriod GaugeLieAlgebra ×
      SmoothQuotientField period hPeriod GaugeLieAlgebra :=
  (completeVariationPairedLinearBRSTGhosts period hPeriod state).independent.ghosts

@[simp] theorem completeVariationPairedU1Parameters_eq_state
    (state : CommonPairedD9LinearBRSTBlock period hPeriod) :
    completeVariationPairedU1Parameters period hPeriod state =
      (state.firstU1.ghost, state.secondU1.ghost) :=
  rfl

/-- Applying the intrinsic U(1)^2 generator to those same ghosts produces
exactly the two genuine one-form potential components of one paired BRST
step.  No coordinate gauge field occurs in this equality. -/
theorem matterGaugeGenerator_completeVariationPairedU1_eq_BRST_potentials
    (fields : IndependentFields period hPeriod)
    (state : CommonPairedD9LinearBRSTBlock period hPeriod) :
    matterGaugeGenerator period hPeriod fields
        (pureU1Parameter period hPeriod
          (completeVariationPairedU1Parameters period hPeriod state)) =
      (0,
        ((commonPairedD9LinearBRSTDifferential period hPeriod state).firstU1.potential,
          (commonPairedD9LinearBRSTDifferential period hPeriod state).secondU1.potential)) := by
  rw [matterGaugeGenerator_pureU1]
  rfl

/-- Finite invariance of the same restricted matter--LL action under the
intrinsic potential shift generated by the paired BRST ghosts. -/
theorem frozenLLMatterGaugeAction_pairedLinearBRSTU1_invariant
    (data : MatterMultipletActionData period hPeriod)
    (frame : SmoothThroatGeneratingFrame period hPeriod)
    (fields : IndependentFields period hPeriod)
    (mu : Measure (EffectiveThroat period hPeriod))
    (base : MatterGaugeVariationSpace period hPeriod)
    (state : CommonPairedD9LinearBRSTBlock period hPeriod) :
    frozenLLMatterGaugeAction period hPeriod data frame fields mu
        (base + matterGaugeGenerator period hPeriod fields
          (pureU1Parameter period hPeriod
            (completeVariationPairedU1Parameters period hPeriod state))) =
      frozenLLMatterGaugeAction period hPeriod data frame fields mu base :=
  frozenLLMatterGaugeAction_pureU1_invariant period hPeriod data frame fields mu
    base (completeVariationPairedU1Parameters period hPeriod state)

/-- Dynamic Noether identity for the same actual Euler covector and the same
paired U(1)^2 ghosts. -/
theorem matterGaugeNoetherOperator_actualEuler_pairedLinearBRSTU1_zero
    (data : MatterMultipletActionData period hPeriod)
    (fields : IndependentFields period hPeriod)
    (base : MatterGaugeVariationSpace period hPeriod)
    (state : CommonPairedD9LinearBRSTBlock period hPeriod) :
    matterGaugeNoetherOperator period hPeriod fields
        (frozenLLMatterGaugeEuler period hPeriod data fields base)
        (pureU1Parameter period hPeriod
          (completeVariationPairedU1Parameters period hPeriod state)) = 0 :=
  matterGaugeNoetherOperator_actualEuler_pureU1_zero period hPeriod data fields
    base (completeVariationPairedU1Parameters period hPeriod state)

end
end P0EFTJanusMatterLLActualU1NoetherPairedLinearBRSTBridge4D
end JanusFormal
