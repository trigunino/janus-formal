import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetCompatibilityBridge4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetProfileL2Bound4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetEulerL2Reduction4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarEnergyGarding4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarNormalEllipticRegularity4D
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarCutoffClosedBoundaryTriple4D

/-!
# Explicit Cauchy-jet PDE closure

The physical boundary triple is now assembled from the standard local and global
PDE statements:

* Euler residual compatibility on the total holonomic atlas;
* the global Euler-skew/divergence integral identity;
* the canonical smooth value and normal cores and tubular inverse;
* a Gårding energy estimate;
* higher elliptic regularity with bounded normal trace;
* integrability of the two fixed Cauchy profiles;
* realization and product estimate of the Euler residual of the explicit jet.

The profile moments give the bulk `L²` component of the extension graph norm.
The local Euler product estimate gives its operator component.  Their maximum
provides the bounded right inverse of the completed Cauchy trace.  Coarea and the
already constructed shrinking cutoffs provide the value trace and minimal-core
density.  Hence these PDE inputs install the genuine completed physical boundary
triple.
-/

namespace JanusFormal
namespace P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetPDEClosure4D

set_option autoImplicit false
noncomputable section

open Set Topology
open P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetCompatibilityGreenCore4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetCompatibilityBridge4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetGeometricGreenCore4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetProfileL2Bound4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarEnergyGarding4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarNormalEllipticRegularity4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarCutoffClosedBoundaryTriple4D
open P0EFTJanusMappingTorusScalarHilbertGreenCoreCompletion4D

universe x y r

variable (period : Real) (hPeriod : period ≠ 0)
variable {massSquared : Real}
variable {Regularity : Type r}
  [NormedAddCommGroup Regularity] [NormedSpace Real Regularity]
  [CompleteSpace Regularity]

/-- Complete explicit-Cauchy PDE input. -/
structure CanonicalPhysicalScalarCauchyJetPDEData
    (massSquared : Real)
    (ValueCore : Type x) (NormalCore : Type y)
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore] where
  geometric : CanonicalPhysicalScalarCauchyJetCompatibilityData
    period hPeriod massSquared ValueCore NormalCore
  gardingEnergy : geometric.greenCore.EnergyGardingData period hPeriod
  normalRegularity : geometric.greenCore.NormalEllipticRegularityData
    period hPeriod (Regularity := Regularity)
  profile : CanonicalLatitudeCauchyJetProfileIntegrabilityData
  eulerRealization : geometric.toCauchyJetGeometricData.CauchyJetEulerProductRealizationData
    period hPeriod
  eulerEstimate : geometric.toCauchyJetGeometricData.CauchyJetEulerProductEstimateData
    period hPeriod eulerRealization

namespace CanonicalPhysicalScalarCauchyJetPDEData

/-- Wave-natural presentation used by the product-coordinate estimate modules. -/
def jetGeometric
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :=
  pde.geometric.toCauchyJetGeometricData

/-- Bulk product estimate generated by the two fixed profile moments. -/
def bulkEstimate
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    pde.jetGeometric.CauchyJetProductL2EstimateData period hPeriod :=
  (pde.jetGeometric period hPeriod).cauchyJetProductL2EstimateData
    period hPeriod pde.profile

/-- Squared bulk and Euler component estimates. -/
def squaredGraphEstimate
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    pde.jetGeometric.CauchyJetSquaredComponentGraphEstimateData period hPeriod :=
  pde.eulerEstimate.combine period hPeriod (pde.bulkEstimate period hPeriod)

/-- Linear component and graph estimates. -/
def graphEstimate
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    pde.jetGeometric.CauchyJetComponentGraphEstimateData period hPeriod :=
  (pde.squaredGraphEstimate period hPeriod).toComponentGraphEstimateData
    period hPeriod

/-- Squared Gårding estimate. -/
def garding
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    pde.jetGeometric.greenCore.SquaredGardingEstimate period hPeriod :=
  pde.gardingEnergy.toSquaredGardingEstimate period hPeriod
    ((pde.jetGeometric period hPeriod).greenCore period hPeriod)

/-- Normal regularity in graph form. -/
def normal
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    pde.jetGeometric.greenCore.NormalRegularityData
      period hPeriod (Regularity := Regularity) :=
  pde.normalRegularity.toNormalRegularityData period hPeriod
    ((pde.jetGeometric period hPeriod).greenCore period hPeriod)

/-- Cutoff-closed completed-boundary input generated by all four PDE layers. -/
def boundaryData
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    CanonicalPhysicalScalarCutoffClosedBoundaryData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity) where
  geometric := (pde.jetGeometric period hPeriod).toGeometricGreenCoreData
    period hPeriod
  garding := pde.garding period hPeriod
  normalRegularity := pde.normal period hPeriod
  extensionConstant :=
    (pde.graphEstimate period hPeriod).graphConstant period hPeriod
  extensionConstant_nonnegative :=
    (pde.graphEstimate period hPeriod).graphConstant_nonnegative period hPeriod
  extensionGraphBound :=
    (pde.graphEstimate period hPeriod).graph_bound period hPeriod

/-- Correct completed physical boundary triple. -/
def triple
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :=
  (pde.boundaryData period hPeriod).triple period hPeriod

/-- Complete physical boundary input package. -/
def completedInputs
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :=
  (pde.boundaryData period hPeriod).completedInputs period hPeriod

/-- Bounded completed Cauchy extension. -/
def completedExtension
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :=
  ((((pde.boundaryData period hPeriod).toFullyGeometricBoundaryData
      period hPeriod).cutoffEllipticBoundaryData period hPeriod)
      |>.toEllipticBoundaryData period hPeriod
      |>.toBoundaryConstructionData period hPeriod)
      |>.completedExtension period hPeriod

/-- Surjectivity of the completed Cauchy trace. -/
theorem completedTraceSurjective
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    Function.Surjective
      (canonicalScalarGreenCoreCompletedBoundaryTrace
        (pde.geometric.greenCore period hPeriod).core
        ((pde.completedInputs period hPeriod).traceBound period hPeriod
          (pde.geometric.greenCore period hPeriod))) :=
  (pde.completedInputs period hPeriod).completedTraceSurjective

/-- The completed extension is a right inverse of the completed trace. -/
theorem completedBoundaryTrace_extension
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity))
    (boundary :
      P0EFTJanusMappingTorusScalarHilbertBoundarySymplectic4D.CanonicalScalarHilbertBoundaryDatum
        (Trace :=
          P0EFTJanusMappingTorusCanonicalPhysicalScalarFirstSheetHilbertTrace4D.CanonicalPhysicalScalarFirstSheetL2
            period)) :
    canonicalScalarGreenCoreCompletedBoundaryTrace
        (pde.geometric.greenCore period hPeriod).core
        ((pde.completedInputs period hPeriod).traceBound period hPeriod
          (pde.geometric.greenCore period hPeriod))
        (pde.completedExtension period hPeriod boundary) = boundary :=
  (((((pde.boundaryData period hPeriod).toFullyGeometricBoundaryData
      period hPeriod).cutoffEllipticBoundaryData period hPeriod)
      |>.toEllipticBoundaryData period hPeriod
      |>.toBoundaryConstructionData period hPeriod)
      |>.certificate period hPeriod).2.2.2.2 boundary

/-- Explicit Cauchy-jet graph bound. -/
theorem extension_graph_bound
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity))
    (data : ValueCore × NormalCore) :
    ‖canonicalScalarGreenCoreToGraph
        (pde.geometric.greenCore period hPeriod).core
        (pde.geometric.extension period hPeriod data)‖ ≤
      (pde.graphEstimate period hPeriod).graphConstant period hPeriod *
        ‖P0EFTJanusMappingTorusScalarBoundarySmoothExtensionDensity4D.canonicalScalarBoundaryCorePairEmbedding
          pde.geometric.boundaryCore.valueEmbedding
          pde.geometric.boundaryCore.normalEmbedding data‖ := by
  exact (pde.squaredGraphEstimate period hPeriod).graph_bound
    period hPeriod data

/-- Explicit-Cauchy PDE closure certificate. -/
theorem certificate
    {ValueCore : Type x} {NormalCore : Type y}
    [AddCommGroup ValueCore] [Module Real ValueCore]
    [AddCommGroup NormalCore] [Module Real NormalCore]
    (pde : CanonicalPhysicalScalarCauchyJetPDEData
      period hPeriod massSquared ValueCore NormalCore
      (Regularity := Regularity)) :
    DenseRange
        (P0EFTJanusMappingTorusCanonicalPhysicalScalarFirstSheetHilbertTrace4D.smoothCanonicalPhysicalScalarFirstSheetCauchyTrace
          period hPeriod) ∧
      (pde.geometric.greenCore period hPeriod).MinimalCoreDense period hPeriod ∧
      Function.Injective
        (canonicalScalarGreenCoreGraphInclusion
          (pde.geometric.greenCore period hPeriod).core) ∧
      Function.Surjective
        (canonicalScalarGreenCoreCompletedBoundaryTrace
          (pde.geometric.greenCore period hPeriod).core
          ((pde.completedInputs period hPeriod).traceBound period hPeriod
            (pde.geometric.greenCore period hPeriod))) ∧
      (∀ data : ValueCore × NormalCore,
        ‖canonicalScalarGreenCoreToGraph
            (pde.geometric.greenCore period hPeriod).core
            (pde.geometric.extension period hPeriod data)‖ ≤
          (pde.graphEstimate period hPeriod).graphConstant period hPeriod *
            ‖P0EFTJanusMappingTorusScalarBoundarySmoothExtensionDensity4D.canonicalScalarBoundaryCorePairEmbedding
              pde.geometric.boundaryCore.valueEmbedding
              pde.geometric.boundaryCore.normalEmbedding data‖) :=
  ⟨pde.geometric.boundaryTrace_denseRange period hPeriod,
    ((pde.boundaryData period hPeriod).certificate period hPeriod).1,
    ((pde.boundaryData period hPeriod).certificate period hPeriod).2.1,
    ((pde.boundaryData period hPeriod).certificate period hPeriod).2.2,
    pde.extension_graph_bound period hPeriod⟩

end CanonicalPhysicalScalarCauchyJetPDEData

end
end P0EFTJanusMappingTorusCanonicalPhysicalScalarCauchyJetPDEClosure4D
end JanusFormal
