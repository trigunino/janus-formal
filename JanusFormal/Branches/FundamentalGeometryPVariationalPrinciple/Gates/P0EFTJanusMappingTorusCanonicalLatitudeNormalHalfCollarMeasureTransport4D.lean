import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusCanonicalPhysicalScalarEulerNormalHalfCollarTransport4D

/-!
# Normal half-collar transport from one measure identity

The analytical transport interface is generated by a single geometric equality
of measures:

`Measure.map transport μ_fullNormal = 2 • μ_positiveCollar`.

Mathlib's map-integral and scalar-measure theorems then provide both preservation
of integrability and the factor-two integral formula for every scalar function.
-/

namespace JanusFormal
namespace P0EFTJanusMappingTorusCanonicalLatitudeNormalHalfCollarMeasureTransport4D

set_option autoImplicit false
noncomputable section

open scoped ENNReal NNReal
open MeasureTheory Set Topology Function
open P0EFTJanusMappingTorusCanonicalPhysicalH1TraceBound4D
open P0EFTJanusMappingTorusCanonicalLatitudeCauchyJetProductCoarea4D
open P0EFTJanusMappingTorusCanonicalPhysicalScalarEulerNormalHalfCollarTransport4D

variable (period : Real)

/-- Field-independent normal transport specified solely by its pushforward
measure. -/
structure CanonicalLatitudeNormalToHalfCollarMeasureTransportData where
  transport : CanonicalLatitudeCauchyJetProductParameter →
    CanonicalLatitudeCollarParameter
  measurable_transport : Measurable transport
  map_measure :
    Measure.map transport (canonicalLatitudeCauchyJetProductMeasure period) =
      (2 : NNReal) • canonicalLatitudeCollarMeasure period

namespace CanonicalLatitudeNormalToHalfCollarMeasureTransportData

/-- The transport is measure preserving when the target is equipped with twice
the collar measure. -/
def measurePreserving
    (data : CanonicalLatitudeNormalToHalfCollarMeasureTransportData period) :
    MeasurePreserving data.transport
      (canonicalLatitudeCauchyJetProductMeasure period)
      ((2 : NNReal) • canonicalLatitudeCollarMeasure period) where
  measurable := data.measurable_transport
  map_eq := data.map_measure

/-- Integrability is transported automatically. -/
theorem integrable_comp
    (data : CanonicalLatitudeNormalToHalfCollarMeasureTransportData period)
    (function : CanonicalLatitudeCollarParameter → Real)
    (hFunction : Integrable function (canonicalLatitudeCollarMeasure period)) :
    Integrable (function ∘ data.transport)
      (canonicalLatitudeCauchyJetProductMeasure period) := by
  have hScaled : Integrable function
      ((2 : NNReal) • canonicalLatitudeCollarMeasure period) :=
    hFunction.smul_measure_nnreal
  exact data.measurePreserving.integrable_comp_of_integrable hScaled

/-- The pushforward measure identity gives the factor-two integral formula. -/
theorem integral_comp
    (data : CanonicalLatitudeNormalToHalfCollarMeasureTransportData period)
    (function : CanonicalLatitudeCollarParameter → Real)
    (hFunction : Integrable function (canonicalLatitudeCollarMeasure period)) :
    (∫ parameter,
      function (data.transport parameter)
      ∂canonicalLatitudeCauchyJetProductMeasure period) =
      2 * ∫ parameter,
        function parameter ∂canonicalLatitudeCollarMeasure period := by
  have hScaled : Integrable function
      ((2 : NNReal) • canonicalLatitudeCollarMeasure period) :=
    hFunction.smul_measure_nnreal
  have hStrong : AEStronglyMeasurable function
      (Measure.map data.transport
        (canonicalLatitudeCauchyJetProductMeasure period)) := by
    rw [data.map_measure]
    exact hScaled.aestronglyMeasurable
  calc
    (∫ parameter,
      function (data.transport parameter)
      ∂canonicalLatitudeCauchyJetProductMeasure period) =
        ∫ parameter, function parameter
          ∂Measure.map data.transport
            (canonicalLatitudeCauchyJetProductMeasure period) :=
      (MeasureTheory.integral_map
        data.measurable_transport.aemeasurable hStrong).symm
    _ = ∫ parameter, function parameter
        ∂((2 : NNReal) • canonicalLatitudeCollarMeasure period) := by
      rw [data.map_measure]
    _ = (2 : NNReal) •
        ∫ parameter, function parameter
          ∂canonicalLatitudeCollarMeasure period := by
      rw [integral_smul_nnreal_measure]
    _ = 2 * ∫ parameter, function parameter
          ∂canonicalLatitudeCollarMeasure period := by
      simp [smul_eq_mul]

/-- Conversion to the former analytical transport interface. -/
def toNormalToHalfCollarTransportData
    (data : CanonicalLatitudeNormalToHalfCollarMeasureTransportData period) :
    CanonicalLatitudeNormalToHalfCollarTransportData period where
  transport := data.transport
  integrable_comp := data.integrable_comp
  integral_comp := data.integral_comp

/-- Measure-transport certificate. -/
theorem certificate
    (data : CanonicalLatitudeNormalToHalfCollarMeasureTransportData period) :
    Measure.map data.transport
        (canonicalLatitudeCauchyJetProductMeasure period) =
      (2 : NNReal) • canonicalLatitudeCollarMeasure period ∧
      (∀ function : CanonicalLatitudeCollarParameter → Real,
        Integrable function (canonicalLatitudeCollarMeasure period) →
          Integrable (function ∘ data.transport)
            (canonicalLatitudeCauchyJetProductMeasure period)) ∧
      (∀ function : CanonicalLatitudeCollarParameter → Real,
        Integrable function (canonicalLatitudeCollarMeasure period) →
          (∫ parameter,
            function (data.transport parameter)
            ∂canonicalLatitudeCauchyJetProductMeasure period) =
          2 * ∫ parameter,
            function parameter ∂canonicalLatitudeCollarMeasure period) :=
  ⟨data.map_measure, data.integrable_comp, data.integral_comp⟩

end CanonicalLatitudeNormalToHalfCollarMeasureTransportData

end
end P0EFTJanusMappingTorusCanonicalLatitudeNormalHalfCollarMeasureTransport4D
end JanusFormal
