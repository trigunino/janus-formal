import Mathlib.Algebra.TrivSqZeroExt.Basic
import JanusFormal.Branches.FundamentalGeometryPVariationalPrinciple.Gates.P0EFTJanusMappingTorusExteriorDiffeomorphismGhostBRST4D

/-!
# Exterior scalar BRST derivation on the D8 quotient

The smallest scalar superalgebra generated by one exterior coefficient is the
trivial square-zero extension `S ⊕ ε S` of the genuine global smooth scalar
algebra `S`.  This gate bundles its parity involution and the scalar BRST rule
as an actual odd graded derivation, proves the Koszul Leibniz rule on the whole
algebra, and proves that its square is zero.

The nonabelian two-ghost scalar square is then computed in the full three-
generator exterior coefficient module.  Its cancellation uses the already
proved D8 Lie-representation identity.  Together with the imported cubic
ghost Jacobi obstruction this closes nilpotence on both scalar and pure-ghost
generators.  No antifields, antibracket, or BV master equation are claimed.
-/

namespace JanusFormal
namespace P0EFTJanusMappingTorusExteriorScalarBRSTDerivation4D

set_option autoImplicit false

noncomputable section

open scoped Manifold ContDiff TensorProduct
open P0EFTJanusMappingTorusQuotient
open P0EFTJanusMappingTorusSmoothAtlasFrontier
open P0EFTJanusMappingTorusSmoothQuotientManifold
open P0EFTJanusMappingTorusSmoothDiffeomorphismGhostLieBracket4D
open P0EFTJanusMappingTorusGradedScalarGhostAction4D
open P0EFTJanusMappingTorusScalarGhostCEClosure4D
open P0EFTJanusMappingTorusExteriorDiffeomorphismGhostBRST4D

variable (period : Real) (hPeriod : period ≠ 0)

private abbrev sphereData := reflectedSphereData period hPeriod
private abbrev EffectiveQuotient := MappingTorus (sphereData period hPeriod)
private abbrev Ghost := CInfinityDiffeomorphismGhost period hPeriod
private abbrev Scalar := CInfinityScalarField period hPeriod

local instance effectiveQuotientChartedSpace :
    ChartedSpace CoverModel (EffectiveQuotient period hPeriod) :=
  reflectedSphereQuotientChartedSpace period hPeriod

local instance effectiveQuotientIsManifold :
    IsManifold coverModelWithCorners ω (EffectiveQuotient period hPeriod) :=
  reflectedSphereQuotient_isManifold period hPeriod

/-- Directional differentiation is a derivation of the genuine pointwise
smooth scalar algebra. -/
theorem cInfinityScalarLieDerivative_mul
    (ghost : Ghost period hPeriod)
    (first second : Scalar period hPeriod) :
    cInfinityScalarLieDerivative period hPeriod ghost (first * second) =
      cInfinityScalarLieDerivative period hPeriod ghost first * second +
        first * cInfinityScalarLieDerivative period hPeriod ghost second := by
  apply ContMDiffMap.ext
  intro point
  change mvfderiv coverModelWithCorners
      ((first : EffectiveQuotient period hPeriod → Real) *
        (second : EffectiveQuotient period hPeriod → Real))
      point (ghost point) = _
  rw [mvfderiv_mul
    (first.contMDiff.mdifferentiableAt (by simp))
    (second.contMDiff.mdifferentiableAt (by simp))]
  change first point *
        mvfderiv coverModelWithCorners second point (ghost point) +
      second point *
        mvfderiv coverModelWithCorners first point (ghost point) =
    mvfderiv coverModelWithCorners first point (ghost point) * second point +
      first point *
        mvfderiv coverModelWithCorners second point (ghost point)
  ring

/-- A `ZMod 2` differential presented by its parity involution.  The last two
fields are precisely oddness and the global Koszul Leibniz identity. -/
structure Z2GradedDifferential (A : Type*) [Ring A] [Algebra Real A] where
  parity : A →ₐ[Real] A
  parity_involutive : ∀ element, parity (parity element) = element
  toLinearMap : A →ₗ[Real] A
  parity_odd : ∀ element,
    parity (toLinearMap element) = -toLinearMap (parity element)
  leibniz : ∀ first second,
    toLinearMap (first * second) =
      toLinearMap first * second + parity first * toLinearMap second
  square_zero : ∀ element, toLinearMap (toLinearMap element) = 0

/-- Concrete scalar superalgebra `S ⊕ ε S`, with `ε² = 0`. -/
abbrev OneGhostScalarSuperalgebra :=
  TrivSqZeroExt (Scalar period hPeriod) (Scalar period hPeriod)

/-- Even scalar inclusion. -/
def evenScalar
    (scalar : Scalar period hPeriod) :
    OneGhostScalarSuperalgebra period hPeriod :=
  TrivSqZeroExt.inl scalar

/-- Odd scalar inclusion. -/
def oddScalar
    (scalar : Scalar period hPeriod) :
    OneGhostScalarSuperalgebra period hPeriod :=
  TrivSqZeroExt.inr scalar

/-- The exterior odd unit `ε`. -/
def oddScalarUnit : OneGhostScalarSuperalgebra period hPeriod :=
  oddScalar period hPeriod 1

@[simp]
theorem oddScalarUnit_sq :
    oddScalarUnit period hPeriod * oddScalarUnit period hPeriod = 0 := by
  simp [oddScalarUnit, oddScalar]

/-- Every element is generated by the smooth scalar algebra and `ε`. -/
theorem oneGhostScalarSuperalgebra_decompose
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    element =
      evenScalar period hPeriod element.fst +
        oddScalarUnit period hPeriod *
          evenScalar period hPeriod element.snd := by
  apply TrivSqZeroExt.ext <;>
    simp [evenScalar, oddScalarUnit, oddScalar]

private def scalarNegLinear :
    Scalar period hPeriod →ₗ[Scalar period hPeriod]
      Scalar period hPeriod :=
  -(LinearMap.id : Scalar period hPeriod →ₗ[Scalar period hPeriod]
    Scalar period hPeriod)

/-- Parity fixes the even component and negates the odd component. -/
def oneGhostScalarParity :
    OneGhostScalarSuperalgebra period hPeriod →ₐ[Real]
      OneGhostScalarSuperalgebra period hPeriod :=
  (TrivSqZeroExt.map (scalarNegLinear period hPeriod)).restrictScalars Real

@[simp]
theorem oneGhostScalarParity_fst
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    (oneGhostScalarParity period hPeriod element).fst = element.fst := by
  exact TrivSqZeroExt.fst_map (scalarNegLinear period hPeriod) element

@[simp]
theorem oneGhostScalarParity_snd
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    (oneGhostScalarParity period hPeriod element).snd = -element.snd := by
  unfold oneGhostScalarParity
  rw [AlgHom.restrictScalars_apply]
  rw [TrivSqZeroExt.snd_map]
  change scalarNegLinear period hPeriod element.snd = -element.snd
  rfl

theorem oneGhostScalarParity_involutive
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    oneGhostScalarParity period hPeriod
        (oneGhostScalarParity period hPeriod element) = element := by
  apply TrivSqZeroExt.ext <;> simp

@[simp]
theorem oneGhostScalarParity_even
    (scalar : Scalar period hPeriod) :
    oneGhostScalarParity period hPeriod
        (evenScalar period hPeriod scalar) =
      evenScalar period hPeriod scalar := by
  apply TrivSqZeroExt.ext <;> simp [evenScalar]

@[simp]
theorem oneGhostScalarParity_oddUnit :
    oneGhostScalarParity period hPeriod
        (oddScalarUnit period hPeriod) =
      -oddScalarUnit period hPeriod := by
  apply TrivSqZeroExt.ext <;> simp [oddScalarUnit, oddScalar]

/-- Linear scalar BRST rule for a fixed genuine smooth D8 ghost.  It sends
`f + ε g` to `-ε L_X f`. -/
def oneGhostScalarBRSTLinear
    (ghost : Ghost period hPeriod) :
    OneGhostScalarSuperalgebra period hPeriod →ₗ[Real]
      OneGhostScalarSuperalgebra period hPeriod where
  toFun element :=
    oddScalar period hPeriod
      (-cInfinityScalarLieDerivative period hPeriod ghost element.fst)
  map_add' first second := by
    apply TrivSqZeroExt.ext
    · simp [oddScalar]
    · simp [oddScalar, cInfinityScalarLieDerivative_addScalar]
      abel
  map_smul' coefficient element := by
    apply TrivSqZeroExt.ext <;>
      simp [oddScalar, cInfinityScalarLieDerivative_smulScalar]

@[simp]
theorem oneGhostScalarBRSTLinear_fst
    (ghost : Ghost period hPeriod)
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    (oneGhostScalarBRSTLinear period hPeriod ghost element).fst = 0 :=
  rfl

@[simp]
theorem oneGhostScalarBRSTLinear_snd
    (ghost : Ghost period hPeriod)
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    (oneGhostScalarBRSTLinear period hPeriod ghost element).snd =
      -cInfinityScalarLieDerivative period hPeriod ghost element.fst :=
  rfl

theorem oneGhostScalarBRSTLinear_parity_odd
    (ghost : Ghost period hPeriod)
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    oneGhostScalarParity period hPeriod
        (oneGhostScalarBRSTLinear period hPeriod ghost element) =
      -oneGhostScalarBRSTLinear period hPeriod ghost
        (oneGhostScalarParity period hPeriod element) := by
  apply TrivSqZeroExt.ext <;>
    simp [oneGhostScalarBRSTLinear, oddScalar]

theorem oneGhostScalarBRSTLinear_leibniz
    (ghost : Ghost period hPeriod)
    (first second : OneGhostScalarSuperalgebra period hPeriod) :
    oneGhostScalarBRSTLinear period hPeriod ghost (first * second) =
      oneGhostScalarBRSTLinear period hPeriod ghost first * second +
        oneGhostScalarParity period hPeriod first *
          oneGhostScalarBRSTLinear period hPeriod ghost second := by
  apply TrivSqZeroExt.ext
  · simp [oneGhostScalarBRSTLinear, oddScalar]
  · simp only [TrivSqZeroExt.snd_add, TrivSqZeroExt.snd_mul,
      TrivSqZeroExt.fst_mul, oneGhostScalarBRSTLinear_fst,
      oneGhostScalarBRSTLinear_snd, oneGhostScalarParity_fst,
      zero_smul, zero_add, smul_zero, add_zero, op_smul_eq_mul,
      smul_eq_mul]
    rw [cInfinityScalarLieDerivative_mul]
    ring

theorem oneGhostScalarBRSTLinear_sq
    (ghost : Ghost period hPeriod)
    (element : OneGhostScalarSuperalgebra period hPeriod) :
    oneGhostScalarBRSTLinear period hPeriod ghost
        (oneGhostScalarBRSTLinear period hPeriod ghost element) = 0 := by
  apply TrivSqZeroExt.ext <;>
    simp [oneGhostScalarBRSTLinear, oddScalar]

/-- The one-ghost scalar BRST operator as an actual square-zero odd graded
derivation on the entire concrete superalgebra. -/
def oneGhostScalarBRSTDifferential
    (ghost : Ghost period hPeriod) :
    Z2GradedDifferential
      (OneGhostScalarSuperalgebra period hPeriod) where
  parity := oneGhostScalarParity period hPeriod
  parity_involutive := oneGhostScalarParity_involutive period hPeriod
  toLinearMap := oneGhostScalarBRSTLinear period hPeriod ghost
  parity_odd := oneGhostScalarBRSTLinear_parity_odd period hPeriod ghost
  leibniz := oneGhostScalarBRSTLinear_leibniz period hPeriod ghost
  square_zero := oneGhostScalarBRSTLinear_sq period hPeriod ghost

/-- The first exterior direction, evaluated into the odd square-zero ideal. -/
def firstOddCoefficientLinear :
    OddGeneratorSpace →ₗ[Real]
      OneGhostScalarSuperalgebra period hPeriod where
  toFun coefficient :=
    oddScalar period hPeriod
      (algebraMap Real (Scalar period hPeriod) (coefficient 0))
  map_add' first second := by
    apply TrivSqZeroExt.ext
    · simp [oddScalar]
    · change
        algebraMap Real (Scalar period hPeriod) (first 0 + second 0) =
          algebraMap Real (Scalar period hPeriod) (first 0) +
            algebraMap Real (Scalar period hPeriod) (second 0)
      rw [map_add]
  map_smul' coefficient vector := by
    apply TrivSqZeroExt.ext
    · simp [oddScalar]
    · change
        algebraMap Real (Scalar period hPeriod) (coefficient * vector 0) =
          coefficient •
            algebraMap Real (Scalar period hPeriod) (vector 0)
      rw [map_mul, Algebra.smul_def]

/-- Algebra map from the genuine three-generator exterior coefficient algebra
onto its first-generator scalar realization. -/
def exteriorCoefficientToOneGhostScalar :
    GhostCoefficientExterior →ₐ[Real]
      OneGhostScalarSuperalgebra period hPeriod :=
  ExteriorAlgebra.lift Real
    ⟨firstOddCoefficientLinear period hPeriod, by
      intro coefficient
      simp [firstOddCoefficientLinear, oddScalar]⟩

@[simp]
theorem exteriorCoefficientToOneGhostScalar_generatorZero :
    exteriorCoefficientToOneGhostScalar period hPeriod (oddGenerator 0) =
      oddScalarUnit period hPeriod := by
  simp [exteriorCoefficientToOneGhostScalar, oddGenerator,
    firstOddCoefficientLinear, oddBasisVector, oddScalarUnit, oddScalar]

/-- Exterior-valued smooth scalar fields. -/
abbrev ExteriorScalarModule :=
  GhostCoefficientExterior ⊗[Real] Scalar period hPeriod

/-- Coefficient-linear action of exterior-valued ghosts on exterior-valued
smooth scalars. -/
def exteriorGhostScalarAction :
    ExteriorDiffeomorphismGhostModule period hPeriod →ₗ[Real]
      ExteriorScalarModule period hPeriod →ₗ[Real]
        ExteriorScalarModule period hPeriod :=
  TensorProduct.map₂
    (LinearMap.mul Real GhostCoefficientExterior)
    (cInfinityScalarGhostAction period hPeriod)

@[simp]
theorem exteriorGhostScalarAction_tmul
    (firstCoefficient secondCoefficient : GhostCoefficientExterior)
    (ghost : Ghost period hPeriod)
    (scalar : Scalar period hPeriod) :
    exteriorGhostScalarAction period hPeriod
        (firstCoefficient ⊗ₜ[Real] ghost)
        (secondCoefficient ⊗ₜ[Real] scalar) =
      (firstCoefficient * secondCoefficient) ⊗ₜ[Real]
        cInfinityScalarLieDerivative period hPeriod ghost scalar := by
  rfl

/-- Even inclusion into the exterior-valued scalar module. -/
def exteriorScalarEmbed
    (scalar : Scalar period hPeriod) :
    ExteriorScalarModule period hPeriod :=
  (1 : GhostCoefficientExterior) ⊗ₜ[Real] scalar

/-- The square of the two-component ghost action is the action of its
quadratic Lie bracket.  This is the D8 representation identity with all
Koszul coefficient signs made explicit. -/
theorem twoGeneratorOddGhost_scalarAction_sq
    (first second : Ghost period hPeriod)
    (scalar : Scalar period hPeriod) :
    exteriorGhostScalarAction period hPeriod
        (twoGeneratorOddGhost period hPeriod first second)
        (exteriorGhostScalarAction period hPeriod
          (twoGeneratorOddGhost period hPeriod first second)
          (exteriorScalarEmbed period hPeriod scalar)) =
      (oddGenerator 0 * oddGenerator 1) ⊗ₜ[Real]
        cInfinityScalarLieDerivative period hPeriod
          (smoothGhostLieBracket period hPeriod first second) scalar := by
  simp only [twoGeneratorOddGhost, oddPureGhost, exteriorScalarEmbed,
    map_add, LinearMap.add_apply, exteriorGhostScalarAction_tmul, mul_one]
  simp only [oddGenerator_sq, TensorProduct.zero_tmul, zero_add, add_zero]
  rw [oddGenerator_anticommute 1 0, TensorProduct.neg_tmul,
    add_comm, ← sub_eq_add_neg, ← TensorProduct.tmul_sub,
    ← cInfinityScalarLieDerivative_bracket period hPeriod first second scalar]

/-- The scalar component of the BRST square dictated by the graded Leibniz
rule, with `s c = -1/2[c,c]` and `s f = -c·f`. -/
def twoGhostScalarBRSTSquare
    (first second : Ghost period hPeriod)
    (scalar : Scalar period hPeriod) :
    ExteriorScalarModule period hPeriod :=
  -exteriorGhostScalarAction period hPeriod
      (nonlinearExteriorGhostBRSTTerm period hPeriod first second)
      (exteriorScalarEmbed period hPeriod scalar) -
    exteriorGhostScalarAction period hPeriod
      (twoGeneratorOddGhost period hPeriod first second)
      (exteriorGhostScalarAction period hPeriod
        (twoGeneratorOddGhost period hPeriod first second)
        (exteriorScalarEmbed period hPeriod scalar))

@[simp]
theorem twoGhostScalarBRSTSquare_zero
    (first second : Ghost period hPeriod)
    (scalar : Scalar period hPeriod) :
    twoGhostScalarBRSTSquare period hPeriod first second scalar = 0 := by
  rw [twoGhostScalarBRSTSquare,
    nonlinearExteriorGhostBRSTTerm_eq]
  simp only [map_neg, LinearMap.neg_apply, neg_neg]
  rw [twoGeneratorOddGhost_scalarAction_sq]
  simp [exteriorScalarEmbed]

theorem exterior_scalar_brst_derivation4D_closure
    (fixed first second third : Ghost period hPeriod)
    (scalar : Scalar period hPeriod)
    (i j k : Fin 3) :
    (∀ element : OneGhostScalarSuperalgebra period hPeriod,
      (oneGhostScalarBRSTDifferential period hPeriod fixed).toLinearMap
        ((oneGhostScalarBRSTDifferential period hPeriod fixed).toLinearMap
          element) = 0) ∧
      twoGhostScalarBRSTSquare period hPeriod first second scalar = 0 ∧
      cubicGhostBRSTJacobiObstruction period hPeriod i j k
        first second third = 0 :=
  ⟨(oneGhostScalarBRSTDifferential period hPeriod fixed).square_zero,
    twoGhostScalarBRSTSquare_zero period hPeriod first second scalar,
    cubicGhostBRSTJacobiObstruction_zero period hPeriod i j k
      first second third⟩

end

end P0EFTJanusMappingTorusExteriorScalarBRSTDerivation4D
end JanusFormal
